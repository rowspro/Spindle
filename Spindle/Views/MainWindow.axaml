<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Spindle.ViewModels"
        xmlns:views="using:Spindle.Views"
        x:Class="Spindle.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="True"
        Width="1040" Height="840" MinWidth="900" MinHeight="640"
        Title="Spindle"
        Background="{DynamicResource Surface}"
        FontFamily="{StaticResource InterFontFamily}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Material 3 light (Spindle design system) -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="Card" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorder" Color="#C3C6D4" />
                    <SolidColorBrush x:Key="Recess" Color="#F3F3F5" />
                    <SolidColorBrush x:Key="Accent" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="HeaderBlue" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="PrimaryBtn" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="PrimaryBtnHover" Color="#3568C4" />
                    <SolidColorBrush x:Key="Success" Color="#2E7D43" />
                    <SolidColorBrush x:Key="SuccessBg" Color="#DCEBDF" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#BA1A1A" />
                    <SolidColorBrush x:Key="ErrorBg" Color="#FFDAD6" />
                    <SolidColorBrush x:Key="ErrorBorder" Color="#E0B4AE" />
                    <SolidColorBrush x:Key="WarnFg" Color="#A55600" />
                    <SolidColorBrush x:Key="WarnBg" Color="#FFE5CC" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#1A1C1D" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#434752" />
                    <SolidColorBrush x:Key="TextMuted" Color="#737783" />
                    <SolidColorBrush x:Key="Surface" Color="#F9F9FB" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#F3F3F5" />
                    <SolidColorBrush x:Key="SurfaceContainer" Color="#EEEEF0" />
                    <SolidColorBrush x:Key="SurfaceVariant" Color="#E2E2E4" />
                    <SolidColorBrush x:Key="PrimaryContainer" Color="#3568C4" />
                    <SolidColorBrush x:Key="OnPrimaryContainer" Color="#E7ECFF" />
                    <SolidColorBrush x:Key="PrimaryFixed" Color="#D8E2FF" />
                    <SolidColorBrush x:Key="PrimaryHover" Color="#EAF0FB" />
                    <SolidColorBrush x:Key="Tertiary" Color="#A55600" />
                    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#0F4FAA" />
                        <GradientStop Offset="1" Color="#3568C4" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <!-- Material 3 dark (fase 5) -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="Card" Color="#1E2026" />
                    <SolidColorBrush x:Key="CardBorder" Color="#383B45" />
                    <SolidColorBrush x:Key="Recess" Color="#171920" />
                    <SolidColorBrush x:Key="Accent" Color="#8AB0FF" />
                    <SolidColorBrush x:Key="HeaderBlue" Color="#8AB0FF" />
                    <SolidColorBrush x:Key="PrimaryBtn" Color="#3D67C9" />
                    <SolidColorBrush x:Key="PrimaryBtnHover" Color="#5380E0" />
                    <SolidColorBrush x:Key="Success" Color="#74D193" />
                    <SolidColorBrush x:Key="SuccessBg" Color="#20392A" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#FF6E66" />
                    <SolidColorBrush x:Key="ErrorBg" Color="#43211E" />
                    <SolidColorBrush x:Key="ErrorBorder" Color="#6B342E" />
                    <SolidColorBrush x:Key="WarnFg" Color="#FFB570" />
                    <SolidColorBrush x:Key="WarnBg" Color="#41301A" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#E6E7EC" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#B8BCC8" />
                    <SolidColorBrush x:Key="TextMuted" Color="#818694" />
                    <SolidColorBrush x:Key="Surface" Color="#121318" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#1A1C22" />
                    <SolidColorBrush x:Key="SurfaceContainer" Color="#262933" />
                    <SolidColorBrush x:Key="SurfaceVariant" Color="#303440" />
                    <SolidColorBrush x:Key="PrimaryContainer" Color="#34508C" />
                    <SolidColorBrush x:Key="OnPrimaryContainer" Color="#DEE7FF" />
                    <SolidColorBrush x:Key="PrimaryFixed" Color="#2B3F66" />
                    <SolidColorBrush x:Key="PrimaryHover" Color="#232C3D" />
                    <SolidColorBrush x:Key="Tertiary" Color="#FFB570" />
                    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#3D67C9" />
                        <GradientStop Offset="1" Color="#6C95F0" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <FontFamily x:Key="IconFont">avares://Spindle/Assets/MaterialIcons.ttf#Material Icons</FontFamily>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <!-- ===== Type scale (Inter) ===== -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LineHeight" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <!-- Icon glyph -->
        <Style Selector="TextBlock.icon">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Tooltip flicker fix: place below the control instead of under the pointer
             (pointer placement made the popup steal hit-testing → flicker + unclickable). -->
        <Style Selector="Button, CheckBox, ToggleSwitch, ComboBox, NumericUpDown">
            <Setter Property="ToolTip.Placement" Value="Bottom" />
            <Setter Property="ToolTip.ShowDelay" Value="500" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #11000000" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="CheckBox:indeterminate /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Slim scrollbars -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="8" />
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="8" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBtn}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBtnHover}" />
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.chip TextBlock.k">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.chip TextBlock.v">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource HeaderBlue}" />
        </Style>
        <Style Selector="Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Sidebar navigation items -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainer}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.nav TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.nav.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainer}" />
        </Style>
        <Style Selector="TextBlock.navGroup">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="12,14,0,4" />
        </Style>

        <!-- Filter-chips (Bibliotheek-browser) -->
        <Style Selector="Button.chipbtn">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="CornerRadius" Value="9999" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.chipbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Button.chipbtn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryFixed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="Button.chipbtn.active">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Format badge on search results: lossless = primary tint, lossy = neutral. -->
        <Style Selector="Border.badge">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Border.badge.lossless">
            <Setter Property="Background" Value="{DynamicResource PrimaryFixed}" />
        </Style>
        <Style Selector="Border.badge.lossless TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <!-- Glass stat cards (Gezondheid) -->
        <Style Selector="Border.stat">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #14000000" />
        </Style>
        <!-- Clickable stat (navigates to a repair flow) -->
        <Style Selector="Button.statbtn">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.statbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="TextBlock.statNum">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.statLbl">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- Sidebar replaces the tab strip; hide the built-in headers. -->
        <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <!-- ...except real sub-tabs (e.g. Settings → General / Personalisations), which keep their strip. -->
        <Style Selector="TabControl.subtabs /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="TabControl.subtabs TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="4,0,16,8" />
        </Style>

        <!-- Inbox: toetsenbord-cursor -->
        <Style Selector="ListBox#InboxList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#InboxList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#InboxList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#InboxList ListBoxItem Border.card">
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="ListBox#InboxList ListBoxItem:selected Border.card">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <!-- Inbound-checklist chips -->
        <Style Selector="Border.checkchip">
            <Setter Property="CornerRadius" Value="9999" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Border.checkchip TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="Border.checkchip.ok">
            <Setter Property="Background" Value="{DynamicResource SuccessBg}" />
        </Style>
        <Style Selector="Border.checkchip.ok TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Success}" />
        </Style>
        <Style Selector="Border.checkchip.warn">
            <Setter Property="Background" Value="{DynamicResource WarnBg}" />
        </Style>
        <Style Selector="Border.checkchip.warn TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WarnFg}" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="12,16,12,14">

                <!-- Logo -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="4,0,0,8">
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" ClipToBounds="True">
                        <Image Source="avares://Spindle/Assets/spindle_1024.png" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Spindle" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Music Manager" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Classes="navGroup" Text="WORKFLOW" />
                        <Button Classes="nav" Tag="5" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=5}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE168;" /><TextBlock Text="Inbox" VerticalAlignment="Center" />
                                <Border CornerRadius="9999" Background="{DynamicResource PrimaryBtn}" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center" IsVisible="{Binding Staging.HasPending}">
                                    <TextBlock Text="{Binding Staging.PendingCount}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                </Border></StackPanel>
                        </Button>

                        <Button Classes="nav" Tag="8" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=8}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE03B;" /><TextBlock Text="Wantlist" VerticalAlignment="Center" /></StackPanel>
                        </Button>

                        <TextBlock Classes="navGroup" Text="LIBRARY" />
                        <Button Classes="nav" Tag="6" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=6}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE030;" /><TextBlock Text="Library" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="7" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=7}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE838;" /><TextBlock Text="Galaxy" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="1" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=1}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xEAA2;" /><TextBlock Text="Health" VerticalAlignment="Center" /></StackPanel>
                        </Button>

                        <TextBlock Classes="navGroup" Text="TOOLS" />
                        <Button Classes="nav" Tag="0" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=0}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE892;" /><TextBlock Text="Metadata" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="2" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=2}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE14D;" /><TextBlock Text="Duplicates" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="3" Click="OnNav" IsVisible="{Binding RockboxMode}"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=3}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE32C;" /><TextBlock Text="Transfer" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: settings -->
                <StackPanel Grid.Row="2">
                    <Button Classes="nav" Tag="4" Click="OnNav"
                            Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=4}">
                        <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE8B8;" /><TextBlock Text="Settings" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Content ===== -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto">

            <!-- Sticky top bar -->
            <Border Grid.Row="0" Height="52" Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto" Margin="24,0">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding CurrentSection}"
                               FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                        <Button Classes="ghost" Padding="8,4" Click="OnOpenHistory" ToolTip.Tip="Activity register — every file move and tag batch of this session, undo from the top.">
                            <TextBlock Classes="icon" FontSize="18" Text="&#xE889;" />
                        </Button>
                        <Button Classes="ghost" Padding="8,4" Click="OnToggleTheme" ToolTip.Tip="Light/dark theme">
                            <TextBlock Classes="icon" FontSize="18" Text="{Binding ThemeIcon}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        <TabControl Grid.Row="1" Margin="24,12,24,16" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" Background="Transparent">

            <!-- ============ TAB: SORTEREN ============ -->
            <!-- ============ TAB: ORGANISEREN ============ -->
            <!-- ============ TAB: ALAC-CONVERTER ============ -->
            <!-- ============ TAB: METADATA ============ -->
            <TabItem Header="Metadata">
                <Grid x:CompileBindings="False" DataContext="{Binding Meta}" RowDefinitions="Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                        <Button Grid.Column="0" Classes="ghost" Content="Open file…" Click="OnOpenMetaFile" />
                        <Button Grid.Column="1" Classes="ghost" Content="Open folder…" Margin="8,0,0,0" Click="OnOpenMetaFolder" />
                        <Button Grid.Column="2" Classes="primary" Margin="8,0,0,0" Command="{Binding MatchAlbumCommand}"
                                ToolTip.Tip="Matches the whole album against one release (Apple/Discogs/MusicBrainz) and applies consistent tags + cover to all tracks.">
                            <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE019;" /><TextBlock Text="Album match" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="ghost" Content="Auto-fill (per track)" Margin="8,0,0,0" Command="{Binding AutoFillCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="Apple format" Margin="8,0,0,0" Command="{Binding ApplyAppleArtistCommand}" />
                        <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="12" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="{DynamicResource HeaderBlue}" FontSize="13" FontWeight="SemiBold" Text="{Binding Position}" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Classes="chipbtn" Content="Form" Command="{Binding ModeFormCommand}" Classes.active="{Binding IsFormMode}" />
                        <Button Classes="chipbtn" Content="Table" Margin="6,0,0,0" Command="{Binding ModeTableCommand}" Classes.active="{Binding IsTableMode}" />
                        <Button Classes="chipbtn" Content="Converters" Margin="6,0,0,0" Command="{Binding ModeConvCommand}" Classes.active="{Binding IsConvMode}" />
                        <TextBlock Classes="caption" Margin="14,0,0,0" VerticalAlignment="Center" Text="{Binding Grid.Status}" />
                    </StackPanel>
                    <Panel Grid.Row="2" Margin="0,14,0,0">
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsFormMode}">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Title" /><TextBox Grid.Column="1" Text="{Binding Title}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Artist" /><TextBox Grid.Column="1" Text="{Binding Artist}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album artist" /><AutoCompleteBox Name="MetaAlbumArtistBox" Grid.Column="1" Text="{Binding AlbumArtist, Mode=TwoWay}" FilterMode="StartsWith" IsTextCompletionEnabled="True" MinimumPrefixLength="1" KeyDown="OnArtistKeyDown" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album" /><TextBox Grid.Column="1" Text="{Binding Album}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Genre" /><TextBox Grid.Column="1" Text="{Binding Genre}" /></Grid>
                            <Grid ColumnDefinitions="110,*,90,*">
                                <TextBlock Grid.Column="0" Classes="label" Text="Track" /><TextBox Grid.Column="1" Text="{Binding Track}" />
                                <TextBlock Grid.Column="2" Classes="label" Text="Disc" Margin="12,0,10,0" /><TextBox Grid.Column="3" Text="{Binding Disc}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Year" /><TextBox Grid.Column="1" Text="{Binding Year}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="AcoustID key" /><TextBox Grid.Column="1" Text="{Binding AcoustIdKey}" Watermark="optional — for untagged files (free via acoustid.org)" /></Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Width="190" Margin="16,0,0,0">
                            <Border Width="190" Height="190" Background="{DynamicResource Recess}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6">
                                <Image Source="{Binding AlbumArt}" Stretch="Uniform" />
                            </Border>
                            <Button Classes="ghost" Content="Choose image…" Margin="0,8,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnLoadMetaArt" />
                            <Button Classes="ghost" Content="Paste cover" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnPasteMetaArt"
                                    ToolTip.Tip="Pastes an image from the clipboard (Mp3tag-style)." />
                            <Button Classes="ghost" Content="Remove cover" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding RemoveArtCommand}" />
                            <Button Classes="primary" Content="Apply to whole album" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding ApplyArtNowCommand}"
                                    ToolTip.Tip="Writes the current cover to all loaded files immediately." />
                        </StackPanel>

                    </Grid>

                    <!-- TABEL-modus (fase 2): Mp3tag-achtige grid-editor -->
                    <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsTableMode}">
                        <WrapPanel Grid.Row="0">
                            <TextBlock Classes="caption" Text="Actions (all rows, as pending changes):" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Button Classes="ghost" Padding="10,5" Content="Apple format" Command="{Binding Grid.ActionAppleCommand}" />
                            <Button Classes="ghost" Padding="10,5" Content="Normalize genre" Margin="6,0,0,0" Command="{Binding Grid.ActionGenreCommand}" />
                            <Button Classes="ghost" Padding="10,5" Content="Trim spaces" Margin="6,0,0,0" Command="{Binding Grid.ActionTrimCommand}" />
                        </WrapPanel>
                        <DataGrid Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Grid.Rows}" AutoGenerateColumns="False"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding DirtyMark}" IsReadOnly="True" Width="28" />
                                <DataGridTextColumn Header="File" Binding="{Binding FileName}" IsReadOnly="True" Width="210" />
                                <DataGridTextColumn Header="Title" Binding="{Binding Title, Mode=TwoWay}" Width="240" />
                                <DataGridTextColumn Header="Artist" Binding="{Binding Artist, Mode=TwoWay}" Width="150" />
                                <DataGridTextColumn Header="Album artist" Binding="{Binding AlbumArtist, Mode=TwoWay}" Width="150" />
                                <DataGridTextColumn Header="Album" Binding="{Binding Album, Mode=TwoWay}" Width="170" />
                                <DataGridTextColumn Header="Genre" Binding="{Binding Genre, Mode=TwoWay}" Width="110" />
                                <DataGridTextColumn Header="#" Binding="{Binding Track, Mode=TwoWay}" Width="46" />
                                <DataGridTextColumn Header="Year" Binding="{Binding Year, Mode=TwoWay}" Width="62" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                            <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Grid.DirtyText}" />
                            <Button Grid.Column="1" Classes="primary" Content="Save changes" Command="{Binding Grid.SaveCommand}"
                                    ToolTip.Tip="Writes the changed rows to the files (Cmd+Z = undo)." />
                        </Grid>
                    </Grid>

                    <!-- CONVERTERS-modus (fase 2) -->
                    <ScrollViewer IsVisible="{Binding IsConvMode}" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <Border Classes="card">
                                <StackPanel>
                                    <TextBlock Classes="title" Text="Filename → Tags" />
                                    <TextBlock Classes="caption" Margin="0,2,0,8" Text="Parses fields from the filename and fills the table as pending changes — review there and click Save." />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Grid.PatternF2T}" Watermark="%artist% - %title%" />
                                        <Button Grid.Column="1" Classes="primary" Margin="8,0,0,0" Content="Fill table" Command="{Binding Grid.ApplyF2TCommand}" />
                                    </Grid>
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="{Binding Grid.PreviewF2T}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Classes="card">
                                <StackPanel>
                                    <TextBlock Classes="title" Text="Tags → Filename" />
                                    <TextBlock Classes="caption" Margin="0,2,0,8" Text="Renames the files based on the (table) tags. Reversible with Cmd+Z." />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Grid.PatternT2F}" Watermark="%track% %title%" />
                                        <Button Grid.Column="1" Classes="primary" Margin="8,0,0,0" Content="Rename files" Command="{Binding Grid.ApplyT2FCommand}" />
                                    </Grid>
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="{Binding Grid.PreviewT2F}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <TextBlock Classes="caption" Text="Tokens: %artist%  %albumartist%  %album%  %title%  %track%  %disc%  %year%  %genre%" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Album-match candidate picker (overlay, alle modi) -->
                    <Border ZIndex="50" IsVisible="{Binding ShowCandidates}"
                                Background="{DynamicResource Surface}" CornerRadius="12">
                            <Border Classes="card">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Classes="h2" Text="Pick the right edition" />
                                        <TextBlock Classes="caption" Margin="0,2,0,0" Text="Applied to ALL tracks of the album: titles by track position + consistent artist/album/year/genre/cover." />
                                    </StackPanel>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding AlbumCandidates}" SelectedItem="{Binding SelectedCandidate}"
                                             Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                                    <Border Grid.Column="0" CornerRadius="9999" Padding="9,3" VerticalAlignment="Center" Background="{DynamicResource PrimaryFixed}">
                                                        <TextBlock Text="{Binding Source}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Display}" Classes="title" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Sub}" Classes="caption" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                                        <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Status}" />
                                        <Button Grid.Column="1" Classes="ghost" Content="Cancel" Command="{Binding CancelCandidatesCommand}" />
                                        <Button Grid.Column="2" Classes="primary" Content="Apply to album" Margin="8,0,0,0" Command="{Binding ApplyAlbumMatchCommand}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Border>
                    </Panel>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="◀ Previous  (←)" Command="{Binding BackCommand}" />
                        <Button Grid.Column="2" Classes="primary" Content="Approve ▶  (→)" Margin="8,0,0,0" Command="{Binding ApproveNextCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: BIBLIOTHEEK ============ -->
            <TabItem Header="Library">
                <Grid x:CompileBindings="False" DataContext="{Binding Library}" RowDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Library health" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Scans your library for missing tags/covers and lossy vs lossless. Click a flagged card to fix those tracks right away." />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowDashboard}">
                      <StackPanel Spacing="14">
                        <!-- Health score hero -->
                        <Border Classes="card" Padding="20">
                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="caption" Text="HEALTH SCORE" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding HealthScore}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                        <TextBlock Text="%" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Bottom" Margin="2,0,0,8" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding HealthScore}" Height="10" CornerRadius="5"
                                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" />
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="Weighted by complete tags, album covers and lossless share." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Library Doctor -->
                        <Border Classes="card" Padding="20">
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="{DynamicResource SurfaceVariant}">
                                    <TextBlock Classes="icon" FontSize="24" Text="&#xE3F3;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource Accent}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Classes="title" Text="Library Doctor" />
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="Finds artist spelling variants (AC/DC vs AC &amp; DC), files that strayed from your naming template, messy genres and album oddities — every fix is one Cmd+Z away from undone." />
                                </StackPanel>
                                <Button Grid.Column="2" Classes="primary" Content="Run checkup" VerticalAlignment="Center"
                                        Command="{Binding OpenDoctorCommand}" />
                            </Grid>
                        </Border>

                        <UniformGrid Columns="3" VerticalAlignment="Top">
                            <Button Classes="statbtn" Command="{Binding ShowFilesCommand}" ToolTip.Tip="Open your library.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Text="{Binding FileCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource SurfaceVariant}">
                                            <TextBlock Classes="icon" Text="&#xE030;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Files" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowAlbumsCommand}" ToolTip.Tip="View all albums; expand an album to see its tracks.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Text="{Binding AlbumCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource SurfaceVariant}">
                                            <TextBlock Classes="icon" Text="&#xE019;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Albums" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowUpgradesCommand}" ToolTip.Tip="See which albums can be upgraded to FLAC.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource Accent}" Text="{Binding UpgradeAlbumCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource PrimaryFixed}">
                                            <TextBlock Classes="icon" Text="&#xF0FB;" HorizontalAlignment="Center" Foreground="{DynamicResource Accent}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="FLAC upgrades possible" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <!-- Clickable: jump to Metadata with the affected files -->
                            <Button Classes="statbtn" Command="{Binding EditNoTagsCommand}"
                                    ToolTip.Tip="Open these tracks in Metadata to complete the tags.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding NoTagCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE892;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="No tags" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Fix" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding EditNoCoverCommand}"
                                    ToolTip.Tip="Open the tracks from albums without art in Metadata to set a cover.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding NoCoverCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE3AD;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Albums without cover" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Fix" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowLossyCommand}"
                                    ToolTip.Tip="View the lossy files and replace them with FLAC.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding LossyFileCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE1B8;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Lossy (MP3/AAC)" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </UniformGrid>

                        <!-- Format mix -->
                        <Border Classes="card" Padding="20" IsVisible="{Binding HasScanned}">
                            <StackPanel>
                                <TextBlock Classes="caption" Text="FORMAT MIX" />
                                <Border Margin="0,12,0,2" Height="14" CornerRadius="7" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                    <Grid Name="FormatBar" />
                                </Border>
                                <ItemsControl ItemsSource="{Binding Formats}" Margin="0,10,0,0">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,18,4">
                                                <Ellipse Width="9" Height="9" Fill="{Binding Brush}" VerticalAlignment="Center" />
                                                <TextBlock Classes="caption" Margin="6,0,0,0" Text="{Binding Label}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Problematische albums -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="title" Text="Problem albums" />
                                <TextBlock Classes="caption" Margin="0,2,0,10" Text="Click 'Fix' to open that album's tracks in Metadata." />
                                <ItemsControl ItemsSource="{Binding ProblemAlbums}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ProblemAlbumViewModel">
                                            <Border Padding="12,9" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center">
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="body" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <Border Grid.Column="1" CornerRadius="9999" Padding="9,3" Margin="8,0,8,0" VerticalAlignment="Center" Background="{DynamicResource WarnBg}">
                                                        <TextBlock Text="{Binding Issue}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                                    </Border>
                                                    <Button Grid.Column="2" Classes="ghost" Padding="12,5" Command="{Binding FixCommand}" Content="Fix" />
                                                    <Button Grid.Column="3" Classes="ghost" Padding="10,5" Margin="6,0,0,0" Command="{Binding DeleteCommand}"
                                                            ToolTip.Tip="Moves this album to '_Verwijderd (Spindle)' next to your library (outside it, reversible) — so sorting/organizing won't bring it back.">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" />
                                                            <TextBlock Text="Delete" VerticalAlignment="Center" Foreground="{DynamicResource ErrorBrush}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                      </StackPanel>
                    </ScrollViewer>

                    <!-- Detail drill-down (clicking a stat box) -->
                    <Grid Grid.Row="1" Margin="0,16,0,0" RowDefinitions="Auto,*" IsVisible="{Binding ShowDetail}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                            <Button Grid.Column="0" Classes="ghost" Command="{Binding CloseDetailCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Classes="icon" FontSize="17" Text="&#xE5C4;" />
                                    <TextBlock Text="Overview" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="14,0,0,0" Classes="h2" Text="{Binding DetailTitle}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" Classes="card" Padding="8">
                            <Grid>
                                <!-- Library Doctor -->
                                <Grid IsVisible="{Binding ShowDoctorPanel}" RowDefinitions="Auto,*" DataContext="{Binding Doctor}">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="6,4,6,10">
                                        <TextBlock Grid.Column="0" Classes="body" Text="{Binding Summary}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="1" Classes="ghost" Content="Fix all locations" Margin="8,0,0,0" Command="{Binding FixAllLocationsCommand}"
                                                ToolTip.Tip="Move every misplaced file to where the template says, in one undoable batch." />
                                        <Button Grid.Column="2" Classes="ghost" Content="Fix all genres" Margin="6,0,0,0" Command="{Binding FixAllGenresCommand}"
                                                ToolTip.Tip="Retag every non-canonical genre in one undoable batch." />
                                        <Button Grid.Column="3" Classes="primary" Content="Re-run checkup" Margin="6,0,0,0" Command="{Binding RunCommand}" />
                                    </Grid>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Findings}" Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="card" Margin="0,0,0,8" Padding="14,10">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" VerticalAlignment="Center">
                                                        <Border Grid.Column="0" CornerRadius="9999" Padding="9,3" Background="{DynamicResource WarnBg}" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Category}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}" Classes="title" FontSize="13.5" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Sub}" Classes="caption" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <ComboBox Grid.Column="2" MinWidth="170" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                  ItemsSource="{Binding Spellings}" SelectedItem="{Binding SelectedSpelling}" IsVisible="{Binding HasSpellings}"
                                                                  ToolTip.Tip="Pick the spelling every track in this cluster should use." />
                                                        <Button Grid.Column="3" Classes="primary" Padding="12,5" VerticalAlignment="Center"
                                                                Command="{Binding FixCommand}" Content="{Binding FixLabel}" IsVisible="{Binding HasFix}" />
                                                        <Button Grid.Column="4" Classes="ghost" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                Command="{Binding EditCommand}" IsVisible="{Binding HasEdit}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Edit in Metadata" VerticalAlignment="Center" /></StackPanel>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>

                                <!-- Albums (tree) -->
                                <TreeView IsVisible="{Binding ShowAlbumsPanel}" ItemsSource="{Binding AlbumTree}" Background="Transparent">
                                    <TreeView.DataTemplates>
                                        <TreeDataTemplate DataType="vm:HealthArtistNode" ItemsSource="{Binding Albums}">
                                            <TextBlock Text="{Binding Name}" Classes="title" FontSize="14" />
                                        </TreeDataTemplate>
                                        <TreeDataTemplate DataType="vm:HealthAlbumNode" ItemsSource="{Binding Tracks}">
                                            <TextBlock Text="{Binding Header}" FontSize="13" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" />
                                        </TreeDataTemplate>
                                    </TreeView.DataTemplates>
                                </TreeView>
                                <!-- Upgrades / Lossy list -->
                                <ScrollViewer IsVisible="{Binding ShowListPanel}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DetailAlbums}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" Margin="2,2,2,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Classes="caption" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Repair covers" Command="{Binding RepairCoversCommand}"
                                ToolTip.Tip="For albums without art, fetches the cover (MusicBrainz/Cover Art Archive) and embeds it in the files + folder.jpg." />
                        <Button Grid.Column="2" Classes="ghost" Content="Stop" Width="80" Margin="8,0,0,0" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="3" Classes="primary" Content="Scan" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: DUBBELE ============ -->
            <TabItem Header="Duplicates">
                <Grid x:CompileBindings="False" DataContext="{Binding Duplicates}" RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Find duplicates" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Finds tracks with the same artist + title and shows the copies side by side. Pick which one to keep per set; the rest goes to the '_Dubbele_verwijderd' folder (reversible)." />
                        <TextBlock Classes="caption" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="The suggested keeper is ranked by: lossless first, then bit depth, sample rate, bitrate and finally file size. Each set explains its pick — overrule with 'Keep this one', or mark a set 'Not a duplicate' (live versions, re-recordings) and it stays hidden from future scans." />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Folder" />
                        <TextBox Grid.Column="1" Text="{Binding Folder}" Watermark="Folder to search (incl. subfolders)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseDupFolder" />
                        <Button Grid.Column="3" Classes="primary" Content="Find duplicates" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                    <CheckBox Grid.Row="2" Margin="0,10,0,0" Content="Also acoustic fingerprint over the rest (AcoustID)" IsChecked="{Binding UseFingerprint}"
                              ToolTip.Tip="Second pass over files that didn't match on tags: recognizes the same recording despite differing/missing tags. Requires an AcoustID key (Metadata tab) and is slow (~3/sec)." />
                    <ScrollViewer Grid.Row="3" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Classes="ghost" Padding="9,3" Content="Not a duplicate" Command="{Binding NotDuplicateCommand}"
                                                        ToolTip.Tip="These are different recordings (live version, remix, re-recording). Removes this set and keeps it hidden in future scans." />
                                            </Grid>
                                            <TextBlock Text="{Binding Reason}" Classes="caption" Margin="0,0,0,8" TextWrapping="Wrap"
                                                       IsVisible="{Binding Reason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="240" Margin="0,0,8,8" Padding="10" CornerRadius="8" Background="{DynamicResource Recess}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding Quality}" Foreground="{DynamicResource HeaderBlue}" FontSize="13" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding Album}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                                                                <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMuted}" FontSize="10" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Path}" />
                                                                <SelectableTextBlock Text="{Binding KeepLabel}" Foreground="{Binding KeepBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                                                <Button Classes="ghost" Content="Keep this one" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding KeepCommand}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Stop" Width="90" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="2" Classes="primary" Content="Delete unchosen" Margin="8,0,0,0" Command="{Binding RemoveCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: OVERZETTEN ============ -->
            <TabItem Header="Transfer">
                <Grid x:CompileBindings="False" DataContext="{Binding Sync}" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="0,12,0,0">
                    <Border Grid.Row="0" Classes="card" Padding="16,14">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="{DynamicResource SurfaceVariant}">
                                <TextBlock Classes="icon" FontSize="26" Text="&#xE32C;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeviceText}" Classes="title" FontSize="15" />
                                <TextBlock Classes="caption" Margin="0,3,0,0" Foreground="{DynamicResource WarnFg}"
                                           Text="⚠ Works with Rockbox iPods only (plain files on disk). Stock Apple firmware needs iTunes/Finder or a tool like iOpenPod." TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0" IsVisible="{Binding HasDevice}">
                                    <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding UsedPercent}" Height="8" CornerRadius="4"
                                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding UsedPercent, StringFormat='{}{0}% vol'}" Classes="caption" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Library" />
                        <TextBox Grid.Column="1" Text="{Binding LibraryFolder}" Watermark="Folder with your music" />
                        <Button Grid.Column="2" Classes="ghost" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseSyncLibrary" />
                        <Button Grid.Column="3" Classes="primary" Content="Scan" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,170,*,Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Genre" />
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" ItemsSource="{Binding Genres}" SelectedItem="{Binding SelectedGenre}" />
                        <TextBox Grid.Column="2" Margin="8,0,0,0" Text="{Binding SearchText}" Watermark="Search artist/album…" />
                        <Button Grid.Column="3" Classes="ghost" Content="All" Margin="8,0,0,0" Command="{Binding SelectAllCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="None" Margin="6,0,0,0" Command="{Binding SelectNoneCommand}" />
                    </Grid>
                    <Border Grid.Row="3" Classes="card" Margin="0,12,0,0">
                        <TreeView ItemsSource="{Binding ArtistTree}">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="vm:ArtistNodeViewModel" ItemsSource="{Binding Albums}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsThreeState="True" IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                        <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </StackPanel>
                                </TreeDataTemplate>
                                <DataTemplate DataType="vm:AlbumEntryViewModel">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1,0,1">
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" IsChecked="{Binding Selected}" />
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding Album}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Sub}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="11" FontWeight="SemiBold"
                                                   Text="{Binding IpodStatus}" Foreground="{Binding IpodBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </Border>
                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="iPod folder" />
                        <TextBox Grid.Column="1" Text="{Binding IpodFolder}" Watermark="The connected iPod (Rockbox)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseSyncIpod" />
                        <Button Grid.Column="4" Classes="ghost" Content="Clean up iPod" Margin="8,0,0,0" Command="{Binding CleanupCommand}"
                                ToolTip.Tip="Finds outdated copies left behind by library renames (duplicate artist folders, old file names next to new ones). Shows a preview first; only touches copies that have a current counterpart." />
                        <Button Grid.Column="3" Classes="ghost" Content="Adopt this iPod" Margin="8,0,0,0" Command="{Binding AdoptCommand}"
                                ToolTip.Tip="Already have music on this iPod from another tool? One-time scan that reads every file's tags (can take a while over USB) so Spindle recognizes existing albums by artist + title — no matter how the files are named or organized. Nothing gets re-transferred." />
                    </Grid>
                    <StackPanel Grid.Row="5" Margin="0,12,0,0">
                    <ProgressBar Height="8" CornerRadius="4" Margin="0,0,0,10" IsVisible="{Binding CleanupBusy}"
                                 IsIndeterminate="{Binding CleanupIndeterminate}" Minimum="0" Maximum="100" Value="{Binding CleanupProgress}"
                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" />
                    <Border CornerRadius="12" Background="{DynamicResource SuccessBg}" Padding="16,14" Margin="0,0,0,10" IsVisible="{Binding ShowCleanupClean}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="✓" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Success}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="This iPod is clean" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Success}" />
                                <TextBlock Text="{Binding CleanupCleanText}" Classes="caption" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="2" Classes="ghost" Padding="10,4" Content="OK" VerticalAlignment="Center" Command="{Binding CancelCleanupCommand}" />
                        </Grid>
                    </Border>
                    <Border Classes="card" Padding="14" Margin="0,0,0,10" IsVisible="{Binding ShowCleanup}">
                        <StackPanel>
                            <TextBlock Classes="title" FontSize="13.5" Text="Outdated copies on the iPod" />
                            <TextBlock Classes="caption" Margin="0,2,0,8" TextWrapping="Wrap" Text="{Binding CleanupSummary}" />
                            <ListBox MaxHeight="180" ItemsSource="{Binding CleanupItems}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12.5" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
                                <Button Classes="primary" Content="Remove from iPod" Command="{Binding ConfirmCleanupCommand}" />
                                <Button Classes="ghost" Content="Cancel" Command="{Binding CancelCleanupCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8" IsVisible="{Binding IsTransferring}">
                        <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" Height="8" CornerRadius="4"
                                     Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Classes="caption" Text="{Binding TransferProgress, StringFormat='{}{0:0}%'}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Convert to ALAC" IsChecked="{Binding ConvertToAlac}"
                                      ToolTip.Tip="Off (default) = copy files as-is (fastest; Rockbox plays FLAC/MP3/AAC). On = only FLAC/WAV/AIFF are converted to ALAC 16-bit/44.1 kHz (saves battery on the iPod); MP3/AAC are always copied as-is." />
                            <TextBlock Text="✓ = on iPod · untick to remove" Margin="16,0,0,0" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{DynamicResource TextMuted}" />
                        </StackPanel>
                        <SelectableTextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="2" Classes="ghost" Content=".m3u playlists" Command="{Binding MakePlaylistsCommand}"
                                ToolTip.Tip="Creates an .m3u playlist per album folder on the iPod (read by Rockbox)." />
                        <Button Grid.Column="3" Classes="ghost" Content="Stop" Width="90" Margin="8,0,0,0" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="4" Classes="primary" Content="Transfer" Margin="8,0,0,0" Command="{Binding TransferCommand}" />
                    </Grid>
                    </StackPanel>
                    <Border Grid.Row="6" Margin="0,10,0,0" Padding="10" CornerRadius="8" Background="{DynamicResource ErrorBg}" BorderBrush="{DynamicResource ErrorBorder}" BorderThickness="1"
                            MaxHeight="150" IsVisible="{Binding HasFailures}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Failed" Foreground="#BA1A1A" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Failures}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <SelectableTextBlock Text="{Binding Line}" ToolTip.Tip="{Binding Path}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,3" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ TAB: INSTELLINGEN ============ -->
            <TabItem Header="Settings">
                <TabControl Classes="subtabs" Background="Transparent" Margin="0,8,0,0">
                  <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                      <StackPanel Spacing="12" Margin="0,0,6,0">

                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Classes="h2" Text="General" />
                            <TextBlock Classes="body" Margin="0,4,0,0" Text="Sources, folders and device mode. Cleanup preferences live under Personalisations." />
                        </StackPanel>

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="section" Text="METADATA SOURCES" />
                                <Grid ColumnDefinitions="105,*">
                                    <TextBlock Grid.Column="0" Classes="label" Text="Discogs token" />
                                    <TextBox Grid.Column="1" Text="{Binding DiscogsToken}" Watermark="optional — free token via discogs.com/settings/developers" />
                                </Grid>
                                <TextBlock Classes="caption" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Album match uses Apple/iTunes (no key needed) + MusicBrainz. A Discogs token adds vinyl/electronic editions." />
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="GALAXY" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,0,0,2"
                                           Text="The visual star-map of your collection. Album level plots one point per album instead of per track — much faster to render on big libraries." />
                                <CheckBox Content="Album level (faster for large collections)" IsChecked="{Binding GalaxyAlbumLevel}"
                                          ToolTip.Tip="One point per album instead of per track. Recommended above ±20,000 tracks (≈ 1 TB)." />
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="title" Text="IPOD MODE" />
                                <ToggleSwitch Margin="0,8,0,0" IsChecked="{Binding ItunesMode}" OnContent="iTunes / stock iPod" OffContent="Rockbox" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,6,0,0" IsVisible="{Binding RockboxMode}"
                                           Text="Rockbox: the Transfer tab copies straight from your music library — no conversion needed (Rockbox plays FLAC natively)." />
                                <StackPanel IsVisible="{Binding ItunesMode}">
                                    <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,6,0,0"
                                               Text="iTunes / stock iPod: Spindle keeps an ALAC mirror of your library in sync automatically, in the background — FLAC/WAV become iPod-ready ALAC (Artist = Album artist), MP3/AAC are copied as-is, removed albums are cleaned up. Point iTunes/Finder at this folder and sync; no manual converting, no waiting." />
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                                        <TextBlock Grid.Column="0" Classes="label" Text="ALAC mirror" />
                                        <TextBox Grid.Column="1" Text="{Binding AlacMirrorFolder}" Watermark="Folder for the ALAC copy (outside your library)" />
                                        <Button Grid.Column="2" Classes="ghost" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseAlacMirror" />
                                    </Grid>
                                    <TextBlock Classes="caption" Margin="0,6,0,0" Text="{Binding MirrorStatus}"
                                               IsVisible="{Binding MirrorStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="section" Text="FOLDERS" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="New music = the inbox Spindle organizes from. Music library = your clean, sorted collection it builds." />
                                <Grid ColumnDefinitions="110,*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="New music" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding DownloadFilePath}" Watermark="Folder where Nicotine+ downloads to (the source to organize)" />
                                    <Button   Grid.Row="0" Grid.Column="2" Classes="ghost" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseDownloadFolder" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Music library" Margin="0,8,10,0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding MusicLibrary}" Watermark="~/Music — your organized collection" />
                                    <Button   Grid.Row="1" Grid.Column="2" Classes="ghost" Margin="8,8,0,0" Content="Browse…" Click="OnBrowseMusicLibrary" />
                                </Grid>
                                <TextBlock Classes="caption" Margin="0,8,0,0" Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold" TextWrapping="Wrap"
                                           Text="{Binding FolderWarning}" IsVisible="{Binding FolderWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </Border>

                      </StackPanel>
                    </ScrollViewer>
                  </TabItem>

                  <TabItem Header="Personalisations">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                      <StackPanel Spacing="12" Margin="0,0,6,0">

                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Classes="h2" Text="Personalisations" />
                            <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="How Spindle cleans your library (Database) and prepares music for the iPod. Database changes are only applied when you run a cleanup action or approve from the Inbox; your source is never touched silently." />
                        </StackPanel>

                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="DATABASE (MY MUSIC)" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,0,0,2"
                                           Text="Preferences the cleanup actions and Inbox approve respect when tidying your local collection." />

                                <CheckBox Content="Split artists on comma" IsChecked="{Binding SplitArtistOnComma}"
                                          ToolTip.Tip="On: a comma separates artists (Beyoncé, Jay-Z → two). Off: keeps 'Last, First' sortnames (White, Jack) intact." />
                                <CheckBox Content="Group collaborations under the primary artist" IsChecked="{Binding GroupCollabsUnderPrimaryArtist}"
                                          ToolTip.Tip="Set Album Artist to the first credited artist so feats/collabs file under one artist." />
                                <CheckBox Content="Apple-style artist names (A, B &amp; C)" IsChecked="{Binding AppleStyleArtistNames}"
                                          ToolTip.Tip="Reformat multi-artist tags to 'A, B &amp; C' with duplicates removed." />
                                <CheckBox Content="Title-case titles &amp; albums" IsChecked="{Binding TitleCaseTitlesAndAlbums}"
                                          ToolTip.Tip="Capitalize titles and album names consistently, keeping small words lowercase." />
                                <CheckBox Content="Keep multiple genres" IsChecked="{Binding KeepMultipleGenres}"
                                          ToolTip.Tip="On: keep every genre (each canonicalized, deduped). Off: reduce a multi-genre tag to its primary genre." />
                                <CheckBox Content="Auto-clean tags when approving from Inbox" IsChecked="{Binding AutoCleanOnApprove}"
                                          ToolTip.Tip="Run the cleanup automatically on approve, instead of only via the manual button." />

                                <TextBlock Classes="label" Text="Filename template (Sort &amp; Organize)" Margin="0,8,0,0" />
                                <TextBox Text="{Binding FilenameTemplate}" Watermark="{}{artist} - {album} - {track} {title}"
                                         ToolTip.Tip="Tokens: {artist} {album} {title} {track} {year}. Empty tokens collapse cleanly. The folder structure stays Artist / Album (Year)." />
                                <TextBlock Text="Tokens: {artist} {album} {title} {track} {year}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="IPOD" />
                                <TextBlock Classes="caption" TextWrapping="Wrap" Margin="0,0,0,2"
                                           Text="How tracks are prepared when transferring to the iPod. The source library is never modified — only the copy on the device." />

                                <CheckBox Content="Flatten artist on sync" IsChecked="{Binding FlattenArtistOnSync}"
                                          ToolTip.Tip="Write only the primary artist on the iPod copy, so Rockbox's artist list doesn't fill up with 'A; B' collab strings." />
                                <CheckBox Content="Convert lossless to ALAC by default" IsChecked="{Binding ConvertToAlacDefault}"
                                          ToolTip.Tip="Default the Transfer tab's 'Convert to ALAC' on. Saves battery on old hardware; required for stock firmware." />
                                <CheckBox Content="Create album playlists (.m3u) after transfer" IsChecked="{Binding AutoCreatePlaylists}"
                                          ToolTip.Tip="Write a .m3u listing the tracks in each album folder on the iPod after a transfer." />
                                <CheckBox Content="Remove macOS junk (._*) after transfer" IsChecked="{Binding RemoveDotUnderscoreAfterTransfer}"
                                          ToolTip.Tip="Delete AppleDouble sidecar files on the iPod after transfer, so Rockbox doesn't index them as phantom duplicate tracks." />
                                <CheckBox Content="Tag various-artist albums as compilations" IsChecked="{Binding SetCompilationFlag}"
                                          ToolTip.Tip="Set the compilation flag on 'Various Artists' albums so the stock iPod groups them under Compilations." />
                            </StackPanel>
                        </Border>

                      </StackPanel>
                    </ScrollViewer>
                  </TabItem>
                </TabControl>
            </TabItem>

            <!-- ============ TAB: NIEUW (review-gate) ============ -->
            <TabItem Header="Inbox">
                <Grid x:CompileBindings="False" DataContext="{Binding Staging}" RowDefinitions="Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="h2" Text="Inbox — review &amp; approve" />
                            <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="What Nicotine+ brought in, per album with attention flags. Fix inline, tick what's good and approve — placed neatly as Artist/Album (Year) in your library after a move preview." />
                            <TextBlock Classes="caption" Margin="0,4,0,0" Text="Keyboard: J/K move · Enter inspect · A select · X delete · Esc back" />
                            <Border CornerRadius="10" Background="{DynamicResource SuccessBg}" Padding="12,8" Margin="0,10,0,0" IsVisible="{Binding HasReceipt}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding LastReceipt}" Foreground="{DynamicResource Success}" FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Classes="ghost" Padding="6,2" Content="✕" Command="{Binding DismissReceiptCommand}" />
                                </Grid>
                            </Border>
                            <TextBlock Classes="body" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="0,8,0,0"
                                       Text="{Binding PipelineText}" IsVisible="{Binding PipelineText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="primary" VerticalAlignment="Top" Command="{Binding ScanCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE8B6;" /><TextBlock Text="Scan inbox" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowAlbumList}">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Classes="caption" Text="{Binding Summary}" />
                        <CheckBox Grid.Column="1" Margin="0,0,12,0" Content="Only issues" IsChecked="{Binding ShowOnlyIssues}" />
                        <Button Grid.Column="2" Classes="ghost" Content="Clean" Command="{Binding SelectCleanCommand}" ToolTip.Tip="Select all clean albums that aren't in the library yet." />
                        <Button Grid.Column="3" Classes="ghost" Content="All" Margin="6,0,0,0" Command="{Binding SelectAllCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="None" Margin="6,0,0,0" Command="{Binding SelectNoneCommand}" />
                        <Button Grid.Column="5" Classes="ghost" Margin="12,0,0,0" Command="{Binding DeleteRedundantCommand}"
                                ToolTip.Tip="Move every album flagged 'already in library — better quality there' to the trash in one undoable batch.">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" />
                                <TextBlock Text="Clear redundant" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                                            <ListBox Grid.Row="2" Name="InboxList" Margin="0,12,0,0" IsVisible="{Binding ShowAlbumList}"
                             ItemsSource="{Binding Albums}" SelectedItem="{Binding CursorAlbum}"
                             Background="Transparent" BorderThickness="0" Padding="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Margin="0,0,0,8" Padding="12">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                                            <CheckBox Grid.Column="0" VerticalAlignment="Center" IsChecked="{Binding IsSelected}" IsEnabled="{Binding CanSelect}" />
                                            <Border Grid.Column="1" Width="56" Height="56" CornerRadius="8" Margin="4,0,0,0" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                                <Panel>
                                                    <TextBlock Classes="icon" FontSize="24" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"
                                                               IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                                    <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Classes="title" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Sub}" Classes="caption" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border CornerRadius="9999" Padding="9,3" Background="{DynamicResource SuccessBg}" IsVisible="{Binding IsClean}">
                                                        <TextBlock Text="✓ clean" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Success}" />
                                                    </Border>
                                                    <ItemsControl ItemsSource="{Binding Flags}">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="9999" Padding="9,3" Margin="0,0,6,0" Background="{DynamicResource WarnBg}">
                                                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Border CornerRadius="9999" Padding="9,3" Background="{DynamicResource SuccessBg}" IsVisible="{Binding ValidationOk}">
                                                        <TextBlock Text="{Binding Validation}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Success}" />
                                                    </Border>
                                                    <Border CornerRadius="9999" Padding="9,3" Background="{DynamicResource SurfaceVariant}" IsVisible="{Binding ValidationInfo}">
                                                        <TextBlock Text="{Binding Validation}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="3" Classes="ghost" VerticalAlignment="Center" Command="{Binding OverrideCommand}" IsVisible="{Binding ShowOverride}"
                                                    ToolTip.Tip="Critical flags keep this album out of the library. Override consciously if you're sure.">
                                                <TextBlock Text="Approve anyway" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                            </Button>
                                            <Button Grid.Column="4" Classes="ghost" VerticalAlignment="Center" Command="{Binding FixCommand}" IsVisible="{Binding HasFlags}">
                                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Fix" VerticalAlignment="Center" /></StackPanel>
                                            </Button>
                                            <Button Grid.Column="5" Classes="primary" Padding="12,5" Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Command="{Binding ReplaceCommand}" IsVisible="{Binding CanReplace}" Content="Replace in library"
                                                    ToolTip.Tip="Moves the old library version to the trash and places this (better) version neatly in the library. Undoable with Cmd+Z." />
                                            <Button Grid.Column="6" Classes="ghost" Padding="8,4" Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Command="{Binding DeleteCommand}"
                                                    ToolTip.Tip="Remove this album from the inbox (to _Verwijderd, reversible).">
                                                <TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    

                    <!-- Map-inspecteur (Fix) -->
                    <Grid Grid.Row="2" Margin="0,12,0,0" RowDefinitions="Auto,Auto,*" IsVisible="{Binding ShowDetail}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,12">
                            <Button Grid.Column="0" Classes="ghost" Command="{Binding BackCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE5C4;" /><TextBlock Text="Back" VerticalAlignment="Center" /></StackPanel>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="14,0,0,0" Classes="h2" Text="{Binding DetailTitle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="2" Classes="ghost" Click="OnInboxCoverChoose" ToolTip.Tip="Choose a cover image and apply it to this whole album.">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE3F4;" /><TextBlock Text="Cover…" VerticalAlignment="Center" /></StackPanel>
                            </Button>
                            <Button Grid.Column="3" Classes="ghost" Margin="6,0,0,0" Click="OnInboxCoverPaste" ToolTip.Tip="Paste a cover from the clipboard and apply it to this whole album.">
                                <TextBlock Classes="icon" FontSize="16" Text="&#xE14F;" />
                            </Button>
                            <Button Grid.Column="4" Classes="ghost" Margin="6,0,0,0" Command="{Binding EditInMetadataCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Edit in Metadata" VerticalAlignment="Center" /></StackPanel>
                            </Button>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding DetailChecks}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="checkchip" Classes.ok="{Binding IsOk}" Classes.warn="{Binding IsWarn}">
                                        <TextBlock Text="{Binding Text}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <Border Classes="card" Padding="14" IsVisible="{Binding HasVersions}">
                                    <StackPanel>
                                        <TextBlock Classes="title" FontSize="13.5" Text="Multiple versions received — keep the best" />
                                        <TextBlock Classes="caption" Margin="0,2,0,8" Text="Pick one; the other folders move to the trash in one undoable batch." />
                                        <ItemsControl ItemsSource="{Binding DetailVersions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,3,0,3">
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DirName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Classes="caption" Text="{Binding Stats}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="9999" Padding="9,3" Margin="8,0" Background="{DynamicResource SuccessBg}" IsVisible="{Binding IsBest}" VerticalAlignment="Center">
                                                            <TextBlock Text="best quality" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Success}" />
                                                        </Border>
                                                        <Button Grid.Column="2" Classes="primary" Padding="12,5" VerticalAlignment="Center" Content="Keep this one" Command="{Binding KeepCommand}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card" IsVisible="{Binding HasDuplicates}">
                                    <StackPanel>
                                        <TextBlock Classes="title" Text="Duplicates in this folder" />
                                        <ItemsControl ItemsSource="{Binding DetailDuplicates}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" />
                                                            <ItemsControl ItemsSource="{Binding Files}" Margin="0,4,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding Meta}" Classes="caption" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                            <Button Grid.Column="1" Classes="ghost" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center" Command="{Binding PlayCommand}" ToolTip.Tip="Play"><TextBlock Classes="icon" FontSize="15" Text="&#xE037;" Foreground="{DynamicResource Accent}" /></Button>
                                                                            <Border Grid.Column="2" Classes="badge" Margin="8,0,8,0" VerticalAlignment="Center"><TextBlock Text="{Binding Format}" /></Border>
                                                                            <Button Grid.Column="3" Classes="ghost" Padding="8,3" VerticalAlignment="Center" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete this file (to _Verwijderd, reversible)."><TextBlock Classes="icon" FontSize="15" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" /></Button>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card">
                                    <StackPanel>
                                        <TextBlock Classes="title" Text="Files" />
                                        <ItemsControl ItemsSource="{Binding DetailFiles}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center">
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}" Classes="title" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Meta}" Classes="caption" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                                <ItemsControl ItemsSource="{Binding Issues}" IsVisible="{Binding HasIssues}" Margin="0,4,0,0">
                                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border CornerRadius="9999" Padding="8,2" Margin="0,0,6,0" Background="{DynamicResource WarnBg}"><TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" /></Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Classes="ghost" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center" Command="{Binding PlayCommand}" ToolTip.Tip="Play"><TextBlock Classes="icon" FontSize="16" Text="&#xE037;" Foreground="{DynamicResource Accent}" /></Button>
                                                            <Border Grid.Column="2" Classes="badge" Margin="8,0,8,0" VerticalAlignment="Center"><TextBlock Text="{Binding Format}" /></Border>
                                                            <Button Grid.Column="3" Classes="ghost" Padding="8,4" VerticalAlignment="Center" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete this file (to _Verwijderd, reversible)."><TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" /></Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Inline taggen (fase 3): tabel in de inspecteur zelf -->
                                <Border Classes="card" Margin="0,12,0,0">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Classes="title" Text="Edit tags (table)" />
                                        <DataGrid Grid.Row="1" Margin="0,8,0,0" MaxHeight="320" ItemsSource="{Binding FixGrid.Rows}" AutoGenerateColumns="False"
                                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                                  Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="" Binding="{Binding DirtyMark}" IsReadOnly="True" Width="24" />
                                                <DataGridTextColumn Header="Title" Binding="{Binding Title, Mode=TwoWay}" Width="240" />
                                                <DataGridTextColumn Header="Artist" Binding="{Binding Artist, Mode=TwoWay}" Width="140" />
                                                <DataGridTextColumn Header="Album" Binding="{Binding Album, Mode=TwoWay}" Width="150" />
                                                <DataGridTextColumn Header="Genre" Binding="{Binding Genre, Mode=TwoWay}" Width="100" />
                                                <DataGridTextColumn Header="#" Binding="{Binding Track, Mode=TwoWay}" Width="42" />
                                                <DataGridTextColumn Header="Year" Binding="{Binding Year, Mode=TwoWay}" Width="56" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                            <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding FixGrid.DirtyText}" />
                                            <Button Grid.Column="1" Classes="primary" Padding="14,6" Content="Save" Command="{Binding FixGrid.SaveCommand}"
                                                    ToolTip.Tip="Writes the changed rows (Cmd+Z = undo)." />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowAlbumList}">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="primary" Command="{Binding ApproveCommand}"
                                ToolTip.Tip="Moves the checked albums into your library, neatly placed by template — with a move preview first.">
                            <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Classes="icon" FontSize="18" Text="&#xE161;" /><TextBlock Text="Approve → library" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </Grid>

                    <!-- Diff-preview van Goedkeuren (fase 3) -->
                    <Grid Grid.Row="0" Grid.RowSpan="4" ZIndex="60" IsVisible="{Binding ShowPlan}">
                        <Border Background="#33000000" />
                        <Border MaxWidth="760" Margin="40,16" Classes="card" VerticalAlignment="Center">
                            <Grid RowDefinitions="Auto,*,Auto" MaxHeight="560">
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Classes="h2" Text="Review the move" />
                                    <TextBlock Classes="caption" Margin="0,4,0,0" Text="{Binding PlanSummary}" />
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding PlanItems}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock Text="{Binding FromText}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Classes="icon" FontSize="14" Text="&#xE5C8;" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding ToText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                                    <Button Grid.Column="1" Classes="ghost" Content="Cancel" Command="{Binding CancelPlanCommand}" />
                                    <Button Grid.Column="2" Classes="primary" Margin="8,0,0,0" Command="{Binding ConfirmPlanCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Classes="icon" FontSize="18" Text="&#xE161;" /><TextBlock Text="Move to library" VerticalAlignment="Center" /></StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: BIBLIOTHEEK-BROWSER (fase 1) ============ -->
            <TabItem Header="Library">
                <Grid x:CompileBindings="False" DataContext="{Binding Browser}" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="h2" Text="Library" />
                                <TextBlock Classes="caption" Margin="0,2,0,0" Text="{Binding Status}" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Top" Command="{Binding RefreshCommand}" ToolTip.Tip="Reload from the index.">
                                <TextBlock Classes="icon" FontSize="17" Text="&#xE5D5;" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,12,0,0">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="Search artist or album…" Margin="0,0,10,0" />
                            <Button Grid.Column="1" Classes="chipbtn" Content="All" Command="{Binding FilterAllCommand}" Classes.active="{Binding IsFilterAll}" />
                            <Button Grid.Column="2" Classes="chipbtn" Content="Lossy" Margin="6,0,0,0" Command="{Binding FilterLossyCommand}" Classes.active="{Binding IsFilterLossy}" />
                            <Button Grid.Column="3" Classes="chipbtn" Content="No cover" Margin="6,0,0,0" Command="{Binding FilterNoCoverCommand}" Classes.active="{Binding IsFilterNoCover}" />
                            <Button Grid.Column="4" Classes="chipbtn" Content="No tags" Margin="6,0,0,0" Command="{Binding FilterNoTagsCommand}" Classes.active="{Binding IsFilterNoTags}" />
                        </Grid>

                        <ListBox Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Albums}" SelectedItem="{Binding SelectedAlbum}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="150" Margin="2">
                                        <Border Width="150" Height="150" CornerRadius="10" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                            <Panel>
                                                <TextBlock Classes="icon" FontSize="44" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                            </Panel>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" Margin="2,8,2,0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ArtistText}" Classes="caption" Margin="2,1,2,0" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="2,4,2,0" IsVisible="{Binding HasIssues}">
                                            <Ellipse Width="7" Height="7" Fill="{DynamicResource WarnFg}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding FlagText}" FontSize="10" Foreground="{DynamicResource WarnFg}" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Inspector -->
                    <Border Grid.Column="1" Width="300" Margin="16,0,0,0" Classes="card" Padding="16"
                            IsVisible="{Binding SelectedAlbum, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Width="260" Height="260" CornerRadius="12" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                    <Panel>
                                        <TextBlock Classes="icon" FontSize="64" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   IsVisible="{Binding SelectedAlbum.Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                        <Image Source="{Binding SelectedAlbum.Cover}" Stretch="UniformToFill" />
                                    </Panel>
                                </Border>
                                <TextBlock Text="{Binding SelectedAlbum.Title}" Classes="title" FontSize="16" Margin="0,12,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedAlbum.ArtistText}" Classes="body" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding SelectedAlbum.Sub}" Classes="caption" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding SelectedAlbum.FlagText}" FontSize="11" Foreground="{DynamicResource WarnFg}" Margin="0,4,0,0"
                                           IsVisible="{Binding SelectedAlbum.HasIssues}" />

                                <TextBlock Classes="section" Text="ALBUM FIELDS (WHOLE ALBUM)" Margin="0,16,0,8" />
                                <AutoCompleteBox Name="LibArtistBox" Text="{Binding EditArtist, Mode=TwoWay}" Watermark="Album artist" FilterMode="StartsWith" IsTextCompletionEnabled="True" MinimumPrefixLength="1" KeyDown="OnArtistKeyDown" />
                                <TextBox Text="{Binding EditAlbum}" Watermark="Album" Margin="0,6,0,0" />
                                <Grid ColumnDefinitions="*,90" Margin="0,6,0,0">
                                    <TextBox Grid.Column="0" Text="{Binding EditGenre}" Watermark="Genre" />
                                    <TextBox Grid.Column="1" Text="{Binding EditYear}" Watermark="Year" Margin="6,0,0,0" />
                                </Grid>
                                <Button Classes="primary" Content="Save for whole album" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                        Command="{Binding SaveAlbumEditCommand}" />

                                <TextBlock Classes="section" Text="TRACKS" Margin="0,16,0,8" />
                                <ListBox MaxHeight="240" ItemsSource="{Binding SelectedTracks}" SelectedItem="{Binding SelectedTrack}"
                                         Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Right}" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Classes="caption" Margin="0,4,0,0" Text="Space = play / pause (plays the album)" />

                                <Button Classes="ghost" Margin="0,14,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding EditInMetadataCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Edit in Metadata" VerticalAlignment="Center" /></StackPanel>
                                </Button>
                                <Button Classes="ghost" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding ShowInFinderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE2C8;" /><TextBlock Text="Show in Finder" VerticalAlignment="Center" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ TAB: GALAXY (fase 4) ============ -->
            <TabItem Header="Galaxy">
                <Grid x:CompileBindings="False" DataContext="{Binding Galaxy}" RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="h2" Text="Galaxy" />
                            <TextBlock Classes="caption" Margin="0,2,0,0" Text="{Binding Status}" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="chipbtn" Content="All" VerticalAlignment="Top" Command="{Binding FilterAllCommand}" Classes.active="{Binding IsFilterAll}" />
                        <Button Grid.Column="2" Classes="chipbtn" Content="Lossy" Margin="6,0,0,0" VerticalAlignment="Top" Command="{Binding FilterLossyCommand}" Classes.active="{Binding IsFilterLossy}" />
                        <Button Grid.Column="3" Classes="chipbtn" Content="No cover" Margin="6,0,0,0" VerticalAlignment="Top" Command="{Binding FilterNoCoverCommand}" Classes.active="{Binding IsFilterNoCover}" />
                        <Button Grid.Column="4" Classes="ghost" Margin="10,0,0,0" VerticalAlignment="Top" Command="{Binding RefreshCommand}" ToolTip.Tip="Rebuild from the index.">
                            <TextBlock Classes="icon" FontSize="17" Text="&#xE5D5;" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="10" Padding="12,8" Background="{DynamicResource WarnBg}" IsVisible="{Binding WarningVisible}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WarnFg}" VerticalAlignment="Center" Text="{Binding WarningText}" />
                            <Button Grid.Column="1" Classes="ghost" Margin="10,0,0,0" Content="Switch to album level" Command="{Binding SwitchToAlbumsCommand}" />
                        </Grid>
                    </Border>

                    <views:GalaxyControl Grid.Row="2" Margin="0,12,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Wantlist">
                <Grid x:CompileBindings="False" DataContext="{Binding Wantlist}" RowDefinitions="Auto,Auto,Auto,*" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Wantlist — close the gaps" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Follow artists and Spindle compares their official discography (MusicBrainz) with your library. Put missing albums on the wantlist, copy the search into Nicotine+ — they tick themselves off the moment they land in your library." />
                    </StackPanel>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <TextBox Grid.Column="0" Text="{Binding FollowName}" Watermark="Artist to follow (e.g. Daft Punk)" KeyDown="OnFollowKeyDown" />
                        <Button Grid.Column="1" Classes="primary" Content="Follow artist" Margin="8,0,0,0" Command="{Binding FollowCommand}" />
                        <Button Grid.Column="2" Classes="ghost" Content="Refresh all" Margin="6,0,0,0" Command="{Binding RefreshAllCommand}"
                                ToolTip.Tip="Re-fetch every followed artist's discography from MusicBrainz." />
                    </Grid>

                    <TextBlock Grid.Row="2" Classes="caption" Margin="0,8,0,0" Text="{Binding Status}" TextWrapping="Wrap" />

                    <Grid Grid.Row="3" ColumnDefinitions="*,340" Margin="0,12,0,0">
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Classes="card" Padding="20" IsVisible="{Binding !HasArtists}">
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="No artists followed yet. Type a name above and press Follow — Spindle shows which of their albums you already own and which are missing." />
                                </Border>
                                <ItemsControl ItemsSource="{Binding Artists}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="card" Margin="0,0,8,10" Padding="16,14">
                                                <StackPanel>
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Classes="title" Text="{Binding Name}" />
                                                            <TextBlock Classes="caption" Text="{Binding Progress}" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Classes="ghost" Padding="8,4" VerticalAlignment="Center" Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh this discography.">
                                                            <TextBlock Classes="icon" FontSize="16" Text="&#xE5D5;" />
                                                        </Button>
                                                        <Button Grid.Column="2" Classes="ghost" Padding="8,4" Margin="4,0,0,0" VerticalAlignment="Center" Command="{Binding UnfollowCommand}" ToolTip.Tip="Stop following this artist.">
                                                            <TextBlock Classes="icon" FontSize="16" Text="&#xE5CD;" />
                                                        </Button>
                                                    </Grid>
                                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding OwnedPercent}" Height="6" CornerRadius="3" Margin="0,10,0,8"
                                                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" />
                                                    <ItemsControl ItemsSource="{Binding Albums}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="24,*,Auto" Margin="0,3,0,3">
                                                                    <TextBlock Grid.Column="0" Text="✓" FontWeight="Bold" Foreground="{DynamicResource Success}" IsVisible="{Binding Owned}" VerticalAlignment="Center" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Display}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                               Foreground="{DynamicResource TextPrimary}" />
                                                                    <Button Grid.Column="2" Classes="ghost" Padding="10,3" Command="{Binding WantCommand}" Content="{Binding WantLabel}" IsVisible="{Binding NotOwned}"
                                                                            ToolTip.Tip="Put this album on the wantlist (press again to remove)." />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="1" Classes="card" Padding="16,14" VerticalAlignment="Stretch">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Classes="title" Text="Wanted" />
                                    <Border CornerRadius="9999" Background="{DynamicResource PrimaryBtn}" Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center" IsVisible="{Binding HasWanted}">
                                        <TextBlock Text="{Binding WantedCount}" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Classes="caption" Margin="0,4,0,10" TextWrapping="Wrap"
                                           Text="Copy a search, download it with Nicotine+ and approve it in the Inbox — it disappears from this list automatically." />
                                <TextBlock Grid.Row="2" Classes="caption" Text="Nothing wanted yet — press '+ Want' on a missing album." IsVisible="{Binding !HasWanted}" />
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="{Binding HasWanted}">
                                    <ItemsControl ItemsSource="{Binding Wanted}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,4">
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Artist}" Classes="caption" />
                                                        <TextBlock Text="{Binding Display}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Classes="ghost" Padding="8,4" Click="OnWantCopy" ToolTip.Tip="Copy the Nicotine+ search for this album.">
                                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE14D;" />
                                                    </Button>
                                                    <Button Grid.Column="2" Classes="ghost" Padding="8,4" Margin="4,0,0,0" Command="{Binding RemoveCommand}" ToolTip.Tip="Remove from the wantlist.">
                                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5CD;" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

            <!-- Mini-speler (ingebouwde music player) -->
            <Border Grid.Row="2" Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,1,0,0" Padding="24,7" IsVisible="{Binding Player.HasTrack}">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                    <Button Grid.Column="0" Classes="ghost" Padding="8,4" Command="{Binding Player.PrevCommand}" ToolTip.Tip="Previous">
                        <TextBlock Classes="icon" FontSize="18" Text="&#xE045;" />
                    </Button>
                    <Button Grid.Column="1" Classes="primary" Padding="10,4" Margin="6,0,0,0" Command="{Binding Player.PlayPauseCommand}" ToolTip.Tip="Play/pause (space)">
                        <TextBlock Classes="icon" FontSize="18" Text="{Binding Player.PlayPauseIcon}" Foreground="White" />
                    </Button>
                    <Button Grid.Column="2" Classes="ghost" Padding="8,4" Margin="6,0,0,0" Command="{Binding Player.NextCommand}" ToolTip.Tip="Next">
                        <TextBlock Classes="icon" FontSize="18" Text="&#xE044;" />
                    </Button>
                    <Button Grid.Column="3" Classes="ghost" Padding="8,4" Margin="6,0,0,0" Command="{Binding Player.StopCommand}" ToolTip.Tip="Stop">
                        <TextBlock Classes="icon" FontSize="18" Text="&#xE047;" />
                    </Button>
                    <StackPanel Grid.Column="4" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Player.NowTitle}" Classes="title" FontSize="13" TextTrimming="CharacterEllipsis" />
                        <Grid ColumnDefinitions="*,Auto" Margin="0,3,0,0">
                            <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding Player.Progress}" Height="4" CornerRadius="2"
                                         Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" Classes="caption" Text="{Binding Player.TimeText}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                    <TextBlock Grid.Column="5" Margin="14,0,0,0" Classes="caption" Text="{Binding Player.NowSub}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280" />
                </Grid>
            </Border>

            <!-- Globale statusbalk (fase 0): indexvoortgang + laatste actie -->
            <Border Grid.Row="3" Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,1,0,0" Padding="24,5">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding GlobalStatus}" />
                    <ProgressBar Grid.Column="1" Width="160" Height="6" CornerRadius="3" Minimum="0" Maximum="100"
                                 Value="{Binding IndexPercent}" IsVisible="{Binding IndexBusy}"
                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}"
                                 VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Cmd+F command palette ===== -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" ZIndex="100" IsVisible="{Binding IsPaletteOpen}">
            <Border Background="#33000000" PointerPressed="OnPaletteBackdrop" />
            <Border VerticalAlignment="Top" HorizontalAlignment="Center" Width="560" Margin="0,90,0,0"
                    Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="8" BoxShadow="0 20 50 0 #44000000">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="8,4">
                        <TextBlock Classes="icon" FontSize="20" Text="&#xE8B6;" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                        <TextBox x:Name="PaletteBox" Grid.Column="1" Margin="8,0,0,0" Text="{Binding PaletteQuery}"
                                 Background="Transparent" BorderThickness="0" FontSize="16"
                                 Watermark="Jump to a screen…" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,6" />
                    <ListBox MaxHeight="360" ItemsSource="{Binding PaletteResults}" SelectedItem="{Binding SelectedPaletteItem}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PaletteItem">
                                <Button Command="{Binding RunCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="Transparent" BorderThickness="0" Padding="8,6">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8" Background="{DynamicResource Recess}">
                                            <TextBlock Classes="icon" FontSize="18" Text="{Binding Glyph}" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Classes="title" FontSize="14" />
                                            <TextBlock Text="{Binding Subtitle}" Classes="caption" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Activity register -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" ZIndex="100" IsVisible="{Binding IsHistoryOpen}">
            <Border Background="#33000000" PointerPressed="OnHistoryBackdrop" />
            <Border VerticalAlignment="Top" HorizontalAlignment="Center" Width="600" Margin="0,90,0,0"
                    Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="16" BoxShadow="0 20 50 0 #44000000">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="icon" FontSize="20" Text="&#xE889;" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                            <TextBlock Classes="title" Text="Activity register" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="ghost" Padding="6,2" Content="✕" Click="OnCloseHistory" />
                    </Grid>
                    <TextBlock Classes="caption" Margin="0,4,0,10" TextWrapping="Wrap"
                               Text="Every inbound movement and tag batch of this session, newest first. Undo peels them off from the top (Cmd+Z does the same)." />
                    <TextBlock Classes="caption" Text="No recorded activity yet this session." IsVisible="{Binding HistoryEmpty}" />
                    <ListBox MaxHeight="380" ItemsSource="{Binding HistoryItems}" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Margin="2,3">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Classes="caption" Text="{Binding Detail}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="ghost" Padding="10,4" Content="Undo" Click="OnUndoTop" IsVisible="{Binding IsTop}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
