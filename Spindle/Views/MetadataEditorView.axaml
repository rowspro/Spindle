<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spindle.ViewModels"
             x:CompileBindings="False"
             x:Class="Spindle.Views.MetadataEditorView">
    <!-- DataContext is a MetadataEditorViewModel, supplied by the host (Metadata tab or Inbox detail). -->
    <UserControl.Styles>
        <Style Selector="ProgressBar.topbusy">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="MinHeight" Value="3" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <!-- Glowing line: shown while this editor is doing work (match, fetch cover/lyrics, auto-fill…). -->
        <Border Grid.RowSpan="5" VerticalAlignment="Top" ZIndex="100" Height="3"
                IsVisible="{Binding AnyBusy}" BoxShadow="0 0 10 0 #803B82F6">
            <ProgressBar Classes="topbusy" IsIndeterminate="True" MinHeight="3" Height="3" />
        </Border>
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
            <Button Grid.Column="0" Classes="ghost" Content="Open file…" Click="OnOpenMetaFile" IsVisible="{Binding ShowSourceButtons}" />
            <Button Grid.Column="1" Classes="ghost" Content="Open folder…" Margin="8,0,0,0" Click="OnOpenMetaFolder" IsVisible="{Binding ShowSourceButtons}" />
            <Button Grid.Column="2" Classes="primary" Command="{Binding MatchAlbumCommand}"
                    ToolTip.Tip="Matches the whole album against one release (Apple/Discogs/MusicBrainz) and applies consistent tags + cover to all tracks.">
                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE019;" /><TextBlock Text="Album match" VerticalAlignment="Center" /></StackPanel>
            </Button>
            <Button Grid.Column="3" Classes="ghost" Content="Auto-fill (per track)" Margin="8,0,0,0" Command="{Binding AutoFillCommand}" />
            <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="12" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="{DynamicResource HeaderBlue}" FontSize="13" FontWeight="SemiBold" Text="{Binding Position}" />
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Classes="chipbtn" Content="Album" Command="{Binding ModeFormCommand}" Classes.active="{Binding IsFormMode}" />
            <Button Classes="chipbtn" Content="Track metadata" Margin="6,0,0,0" Command="{Binding ModeTableCommand}" Classes.active="{Binding IsTableMode}" />
            <TextBlock Classes="caption" Margin="14,0,0,0" VerticalAlignment="Center" Text="{Binding Grid.Status}"
                       IsVisible="{Binding !AlbumMatchBlocked}" />
            <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                       MaxWidth="640" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource WarnFg}"
                       Text="{Binding AlbumMatchBlockReason}" ToolTip.Tip="{Binding AlbumMatchBlockReason}"
                       IsVisible="{Binding AlbumMatchBlocked}" />
        </StackPanel>
        <!-- Album health checks + inbox-only pruning (versions / duplicates) -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
            <Border Classes="card" Padding="10,7" IsVisible="{Binding HasAlbumQueue}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Classes="title" FontSize="13" VerticalAlignment="Center" Text="{Binding AlbumQueuePosition}" />
                    <TextBlock Grid.Column="1" Classes="caption" Margin="12,0,0,0" VerticalAlignment="Center"
                               Text="Editing several albums in a row — finish this one, then go to the next." />
                    <Button Grid.Column="2" Classes="ghost" Command="{Binding PrevAlbumCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE5C4;" /><TextBlock Text="Previous album" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                    <Button Grid.Column="3" Classes="primary" Margin="6,0,0,0" Command="{Binding NextAlbumCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="Next album" VerticalAlignment="Center" /><TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" /></StackPanel>
                    </Button>
                </Grid>
            </Border>
            <ItemsControl ItemsSource="{Binding Checks}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="checkchip" Classes.ok="{Binding IsOk}" Classes.warn="{Binding IsWarn}"><TextBlock Text="{Binding Text}" /></Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Classes="card" Padding="12" IsVisible="{Binding HasVersions}">
                <StackPanel>
                    <TextBlock Classes="title" FontSize="13" Text="Multiple versions received — keep the best" />
                    <TextBlock Classes="caption" Margin="0,2,0,8" Text="Pick one; the other folders move to the trash in one undoable batch." />
                    <ItemsControl ItemsSource="{Binding Versions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,3,0,3">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DirName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Classes="caption" Text="{Binding Stats}" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="9999" Padding="9,3" Margin="8,0" Background="{DynamicResource SuccessBg}" IsVisible="{Binding IsBest}" VerticalAlignment="Center">
                                        <TextBlock Text="best quality" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Success}" />
                                    </Border>
                                    <Button Grid.Column="2" Classes="primary" Padding="12,5" VerticalAlignment="Center" Content="Keep this one" Command="{Binding KeepCommand}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Classes="card" IsVisible="{Binding HasDuplicates}">
                <StackPanel>
                    <TextBlock Classes="title" Text="Duplicates in this folder" />
                    <ItemsControl ItemsSource="{Binding Duplicates}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" />
                                        <ItemsControl ItemsSource="{Binding Files}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Meta}" Classes="caption" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Classes="ghost" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center" Command="{Binding PlayCommand}" ToolTip.Tip="Play"><TextBlock Classes="icon" FontSize="15" Text="&#xE037;" Foreground="{DynamicResource Accent}" /></Button>
                                                        <Border Grid.Column="2" Classes="badge" Margin="8,0,8,0" VerticalAlignment="Center"><TextBlock Text="{Binding Format}" /></Border>
                                                        <Button Grid.Column="3" Classes="ghost" Padding="8,3" VerticalAlignment="Center" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete this file (to _Verwijderd, reversible)."><TextBlock Classes="icon" FontSize="15" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" /></Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <Panel Grid.Row="3" Margin="0,14,0,0">
        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsFormMode}">
            <StackPanel Grid.Column="0" Spacing="8">
                <!-- Album-wide fields: written to every track of the album on Save -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Classes="section" Text="ALBUM" VerticalAlignment="Center" />
                    <Border CornerRadius="9999" Padding="9,2" Background="{DynamicResource SurfaceVariant}" VerticalAlignment="Center" IsVisible="{Binding IsAlbumScope}">
                        <TextBlock Text="{Binding AlbumScopeText}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                    </Border>
                </StackPanel>
                <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album" /><TextBox Grid.Column="1" Text="{Binding Album}" /></Grid>
                <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album artist" /><AutoCompleteBox Grid.Column="1" Text="{Binding AlbumArtist, Mode=TwoWay}" ItemsSource="{Binding ArtistSuggestions}" FilterMode="StartsWith" IsTextCompletionEnabled="True" MinimumPrefixLength="1" KeyDown="OnArtistKeyDown" /></Grid>
                <Grid ColumnDefinitions="110,*">
                    <TextBlock Classes="label" Text="Genre" />
                    <AutoCompleteBox Grid.Column="1" Text="{Binding Genre, Mode=TwoWay}" ItemsSource="{Binding GenreOptions}"
                                     FilterMode="Contains" IsTextCompletionEnabled="True" MinimumPrefixLength="0"
                                     Watermark="Pick a standard genre or type your own" />
                </Grid>
                <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Year" /><TextBox Grid.Column="1" Text="{Binding Year}" /></Grid>
                <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="AcoustID key" /><TextBox Grid.Column="1" Text="{Binding AcoustIdKey}" Watermark="optional — for untagged files (free via acoustid.org)" /></Grid>

                <Button Classes="ghost" Margin="0,8,0,0" HorizontalAlignment="Left" Content="Fetch lyrics for all tracks" Command="{Binding FetchLyricsCommand}"
                        ToolTip.Tip="Look up lyrics on LRCLIB (online) for every track of the album: synced → .lrc next to the file, plain → embedded lyrics tag." />
            </StackPanel>
            <StackPanel Grid.Column="1" Width="190" Margin="16,0,0,0">
                <Border Width="190" Height="190" Background="{DynamicResource Recess}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6">
                    <Image Source="{Binding AlbumArt}" Stretch="Uniform" />
                </Border>
                <Button Classes="ghost" Content="Choose cover from Finder" Margin="0,8,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnLoadMetaArt" />
                <Button Classes="ghost" Content="Fetch cover" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding FetchCoverCommand}"
                        ToolTip.Tip="Fetch only the album art via our tools (Apple/Discogs/MusicBrainz). No other tags are touched." />
                <TextBlock Classes="caption" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"
                           Text="Cover is part of the album — saved to every track." />
            </StackPanel>
        </Grid>

        <!-- TRACK METADATA mode: Mp3tag-style grid editor (per-track fields) -->
        <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsTableMode}">
            <TextBlock Grid.Row="0" Classes="caption"
                       Text="Per-track tags. Album-wide fields (album, album artist, genre, year, cover) live in the Album tab. Spaces are tidied automatically on save." />
            <DataGrid Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Grid.Rows}" AutoGenerateColumns="False"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      CanUserResizeColumns="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="" Binding="{Binding DirtyMark}" IsReadOnly="True" Width="28" />
                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" IsReadOnly="True" Width="210" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title, Mode=TwoWay}" Width="240" />
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist, Mode=TwoWay}" Width="150" />
                    <DataGridTextColumn Header="Album artist" Binding="{Binding AlbumArtist, Mode=TwoWay}" Width="150" />
                    <DataGridTextColumn Header="Album" Binding="{Binding Album, Mode=TwoWay}" Width="170" />
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre, Mode=TwoWay}" Width="110" />
                    <DataGridTextColumn Header="#" Binding="{Binding Track, Mode=TwoWay}" Width="46" CustomSortComparer="{x:Static vm:TrackNumberComparer.Instance}" />
                    <DataGridTextColumn Header="Year" Binding="{Binding Year, Mode=TwoWay}" Width="62" />
                </DataGrid.Columns>
            </DataGrid>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Grid.DirtyText}" />
                <Button Grid.Column="1" Classes="primary" Content="Save changes" Command="{Binding Grid.SaveCommand}"
                        ToolTip.Tip="Writes the changed rows to the files (Cmd+Z = undo)." />
            </Grid>
        </Grid>

        <!-- Album-match candidate picker (overlay, all modes) -->
        <Border ZIndex="50" IsVisible="{Binding ShowCandidates}"
                Background="{DynamicResource Surface}" CornerRadius="12">
            <Border Classes="card">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Classes="h2" Text="Pick the right edition" />
                        <TextBlock Classes="caption" Margin="0,2,0,0" Text="Applied to ALL tracks of the album: titles by track position + consistent artist/album/year/genre/cover." />
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding AlbumCandidates}" SelectedItem="{Binding SelectedCandidate}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                    <Border Grid.Column="0" CornerRadius="9999" Padding="9,3" VerticalAlignment="Center" Background="{DynamicResource PrimaryFixed}">
                                        <TextBlock Text="{Binding Source}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Display}" Classes="title" FontSize="14" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Sub}" Classes="caption" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Cancel" Command="{Binding CancelCandidatesCommand}" />
                        <Button Grid.Column="2" Classes="primary" Content="Apply to album" Margin="8,0,0,0" Command="{Binding ApplyAlbumMatchCommand}" />
                    </Grid>
                </Grid>
            </Border>
        </Border>
        </Panel>
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
            <Button Grid.Column="1" Classes="primary" Content="Save" Command="{Binding SaveCommand}" IsVisible="{Binding IsFormMode}"
                    ToolTip.Tip="Save the tag edits to this track. Approving the whole album happens in the Inbox when it's correct and complete." />
        </Grid>
    </Grid>
</UserControl>
