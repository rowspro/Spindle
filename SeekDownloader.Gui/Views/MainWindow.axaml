<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SeekDownloader.Gui.ViewModels"
        xmlns:views="using:SeekDownloader.Gui.Views"
        x:Class="SeekDownloader.Gui.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:CompileBindings="True"
        Width="1040" Height="840" MinWidth="900" MinHeight="640"
        Title="Spindle"
        Background="{DynamicResource Surface}"
        FontFamily="{StaticResource InterFontFamily}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Material 3 light (Spindle design system) -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="Card" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorder" Color="#C3C6D4" />
                    <SolidColorBrush x:Key="Recess" Color="#F3F3F5" />
                    <SolidColorBrush x:Key="Accent" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="HeaderBlue" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="PrimaryBtn" Color="#0F4FAA" />
                    <SolidColorBrush x:Key="PrimaryBtnHover" Color="#3568C4" />
                    <SolidColorBrush x:Key="Success" Color="#2E7D43" />
                    <SolidColorBrush x:Key="SuccessBg" Color="#DCEBDF" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#BA1A1A" />
                    <SolidColorBrush x:Key="ErrorBg" Color="#FFDAD6" />
                    <SolidColorBrush x:Key="ErrorBorder" Color="#E0B4AE" />
                    <SolidColorBrush x:Key="WarnFg" Color="#A55600" />
                    <SolidColorBrush x:Key="WarnBg" Color="#FFE5CC" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#1A1C1D" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#434752" />
                    <SolidColorBrush x:Key="TextMuted" Color="#737783" />
                    <SolidColorBrush x:Key="Surface" Color="#F9F9FB" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#F3F3F5" />
                    <SolidColorBrush x:Key="SurfaceContainer" Color="#EEEEF0" />
                    <SolidColorBrush x:Key="SurfaceVariant" Color="#E2E2E4" />
                    <SolidColorBrush x:Key="PrimaryContainer" Color="#3568C4" />
                    <SolidColorBrush x:Key="OnPrimaryContainer" Color="#E7ECFF" />
                    <SolidColorBrush x:Key="PrimaryFixed" Color="#D8E2FF" />
                    <SolidColorBrush x:Key="PrimaryHover" Color="#EAF0FB" />
                    <SolidColorBrush x:Key="Tertiary" Color="#A55600" />
                    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#0F4FAA" />
                        <GradientStop Offset="1" Color="#3568C4" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <!-- Material 3 dark (fase 5) -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="Card" Color="#1E2026" />
                    <SolidColorBrush x:Key="CardBorder" Color="#383B45" />
                    <SolidColorBrush x:Key="Recess" Color="#171920" />
                    <SolidColorBrush x:Key="Accent" Color="#8AB0FF" />
                    <SolidColorBrush x:Key="HeaderBlue" Color="#8AB0FF" />
                    <SolidColorBrush x:Key="PrimaryBtn" Color="#3D67C9" />
                    <SolidColorBrush x:Key="PrimaryBtnHover" Color="#5380E0" />
                    <SolidColorBrush x:Key="Success" Color="#74D193" />
                    <SolidColorBrush x:Key="SuccessBg" Color="#20392A" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#FF6E66" />
                    <SolidColorBrush x:Key="ErrorBg" Color="#43211E" />
                    <SolidColorBrush x:Key="ErrorBorder" Color="#6B342E" />
                    <SolidColorBrush x:Key="WarnFg" Color="#FFB570" />
                    <SolidColorBrush x:Key="WarnBg" Color="#41301A" />
                    <SolidColorBrush x:Key="TextPrimary" Color="#E6E7EC" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#B8BCC8" />
                    <SolidColorBrush x:Key="TextMuted" Color="#818694" />
                    <SolidColorBrush x:Key="Surface" Color="#121318" />
                    <SolidColorBrush x:Key="SidebarBg" Color="#1A1C22" />
                    <SolidColorBrush x:Key="SurfaceContainer" Color="#262933" />
                    <SolidColorBrush x:Key="SurfaceVariant" Color="#303440" />
                    <SolidColorBrush x:Key="PrimaryContainer" Color="#34508C" />
                    <SolidColorBrush x:Key="OnPrimaryContainer" Color="#DEE7FF" />
                    <SolidColorBrush x:Key="PrimaryFixed" Color="#2B3F66" />
                    <SolidColorBrush x:Key="PrimaryHover" Color="#232C3D" />
                    <SolidColorBrush x:Key="Tertiary" Color="#FFB570" />
                    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Offset="0" Color="#3D67C9" />
                        <GradientStop Offset="1" Color="#6C95F0" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <FontFamily x:Key="IconFont">avares://Spindle/Assets/MaterialIcons.ttf#Material Icons</FontFamily>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <!-- ===== Type scale (Inter) ===== -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="LineHeight" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <!-- Icon glyph -->
        <Style Selector="TextBlock.icon">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Tooltip flicker fix: place below the control instead of under the pointer
             (pointer placement made the popup steal hit-testing → flicker + unclickable). -->
        <Style Selector="Button, CheckBox, ToggleSwitch, ComboBox, NumericUpDown">
            <Setter Property="ToolTip.Placement" Value="Bottom" />
            <Setter Property="ToolTip.ShowDelay" Value="500" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #11000000" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>
        <Style Selector="CheckBox:indeterminate /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Recess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Slim scrollbars -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="8" />
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="8" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBtn}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBtnHover}" />
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.chip TextBlock.k">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.chip TextBlock.v">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource HeaderBlue}" />
        </Style>
        <Style Selector="Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Sidebar navigation items -->
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Button.nav.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainer}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.nav TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.nav.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainer}" />
        </Style>
        <Style Selector="TextBlock.navGroup">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="12,14,0,4" />
        </Style>

        <!-- Filter-chips (Bibliotheek-browser) -->
        <Style Selector="Button.chipbtn">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainer}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="CornerRadius" Value="9999" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="Button.chipbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Button.chipbtn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryFixed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="Button.chipbtn.active">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Format badge on search results: lossless = primary tint, lossy = neutral. -->
        <Style Selector="Border.badge">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource SurfaceVariant}" />
        </Style>
        <Style Selector="Border.badge TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Border.badge.lossless">
            <Setter Property="Background" Value="{DynamicResource PrimaryFixed}" />
        </Style>
        <Style Selector="Border.badge.lossless TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <!-- Glass stat cards (Gezondheid) -->
        <Style Selector="Border.stat">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #14000000" />
        </Style>
        <!-- Clickable stat (navigates to a repair flow) -->
        <Style Selector="Button.statbtn">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.statbtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryContainer}" />
        </Style>
        <Style Selector="TextBlock.statNum">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TextBlock.statLbl">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <!-- Sidebar replaces the tab strip; hide the built-in headers. -->
        <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" Margin="12,16,12,14">

                <!-- Logo -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="4,0,0,8">
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" ClipToBounds="True">
                        <Image Source="avares://Spindle/Assets/spindle_1024.png" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Spindle" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Music Manager" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                    </StackPanel>
                </Grid>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Classes="navGroup" Text="WORKFLOW" />
                        <Button Classes="nav" Tag="8" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=8}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE168;" /><TextBlock Text="Nieuw" VerticalAlignment="Center" /></StackPanel>
                        </Button>

                        <TextBlock Classes="navGroup" Text="BIBLIOTHEEK" />
                        <Button Classes="nav" Tag="9" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=9}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE030;" /><TextBlock Text="Bibliotheek" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="10" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=10}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE838;" /><TextBlock Text="Galaxy" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="4" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=4}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xEAA2;" /><TextBlock Text="Gezondheid" VerticalAlignment="Center" /></StackPanel>
                        </Button>

                        <TextBlock Classes="navGroup" Text="GEREEDSCHAP" />
                        <Button Classes="nav" Tag="1" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=1}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE663;" /><TextBlock Text="Organiseren" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="0" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=0}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE164;" /><TextBlock Text="Sorteren" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="3" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=3}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE892;" /><TextBlock Text="Metadata" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="5" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=5}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE14D;" /><TextBlock Text="Dubbele" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="2" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=2}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE1B8;" /><TextBlock Text="ALAC-converter" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Classes="nav" Tag="6" Click="OnNav"
                                Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=6}">
                            <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE32C;" /><TextBlock Text="Overzetten" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: settings -->
                <StackPanel Grid.Row="2">
                    <Button Classes="nav" Tag="7" Click="OnNav"
                            Classes.active="{Binding SelectedTabIndex, Converter={x:Static vm:IntEquals.Instance}, ConverterParameter=7}">
                        <StackPanel Orientation="Horizontal"><TextBlock Classes="icon" FontSize="19" Width="28" Text="&#xE8B8;" /><TextBlock Text="Instellingen" VerticalAlignment="Center" /></StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Content ===== -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">

            <!-- Sticky top bar -->
            <Border Grid.Row="0" Height="52" Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto" Margin="24,0">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding CurrentSection}"
                               FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                        <Button Classes="ghost" Padding="8,4" Click="OnToggleTheme" ToolTip.Tip="Licht/donker thema">
                            <TextBlock Classes="icon" FontSize="18" Text="{Binding ThemeIcon}" />
                        </Button>
                        <TextBlock Classes="icon" FontSize="20" Text="&#xE7F4;" Foreground="{DynamicResource TextMuted}" />
                        <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource PrimaryContainer}">
                            <TextBlock Text="{Binding UserInitial}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

        <TabControl Grid.Row="1" Margin="24,12,24,16" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" Background="Transparent">

            <!-- ============ TAB: SORTEREN ============ -->
            <TabItem Header="Sorteren">
                <Grid x:CompileBindings="False" DataContext="{Binding Sort}" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Sorteren" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Ordent een map op basis van de tags naar: Artiest / Album (Jaar) / 'hoofdartiest - album - ## titel'. Compilaties komen onder 'Various Artists'. Gebruikt de album-artiest, splitst geen namen. 'Genre opschonen' zet het genre om naar één canonieke waarde." />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Map" />
                        <TextBox Grid.Column="1" Text="{Binding SourceFolder}" Watermark="Map om te sorteren" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseSortSource" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Doelmap" />
                        <TextBox Grid.Column="1" Text="{Binding DestFolder}" Watermark="Optioneel — leeg = in dezelfde map sorteren" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseSortDest" />
                    </Grid>
                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <CheckBox Margin="0,0,16,0" Content="Alleen tonen (test)" IsChecked="{Binding TestMode}" />
                        <CheckBox Margin="0,0,16,0" Content="Lege mappen opruimen" IsChecked="{Binding CleanEmpty}" />
                        <CheckBox Content="Genre opschonen" IsChecked="{Binding CleanGenre}"
                                  ToolTip.Tip="Schrijft één canonieke genre terug (bijv. alle hip-hop-varianten → Hip-Hop/Rap; lange reeksen → de primaire genre). Werkt alleen bij echt sorteren, niet in testmodus." />
                    </WrapPanel>
                    <Border Grid.Row="4" Classes="card" Margin="0,12,0,0">
                        <TreeView ItemsSource="{Binding Tree}">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="vm:SortArtistGroupViewModel" ItemsSource="{Binding Albums}">
                                    <TextBlock Text="{Binding Header}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" />
                                </TreeDataTemplate>
                                <TreeDataTemplate DataType="vm:SortAlbumGroupViewModel" ItemsSource="{Binding Files}">
                                    <TextBlock Text="{Binding Header}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                                </TreeDataTemplate>
                                <DataTemplate DataType="vm:SortItemViewModel">
                                    <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="6,2" Command="{Binding ShowCommand}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </Border>
                    <Border Grid.Row="5" Margin="0,10,0,0" Padding="10" CornerRadius="8" Background="#EEEEF0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <SelectableTextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                    <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Ongedaan maken" Command="{Binding UndoCommand}"
                                ToolTip.Tip="Zet de laatste sorteer-/organiseer-actie terug (laatste batch verplaatsingen)." />
                        <Button Grid.Column="2" Classes="primary" Content="Sorteer" Margin="8,0,0,0" Command="{Binding SortCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: ORGANISEREN ============ -->
            <TabItem Header="Organiseren">
                <Grid x:CompileBindings="False" DataContext="{Binding Organize}" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Organiseren" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Alles-in-één: matcht elk album tegen MusicBrainz, vult/poetst de tags (Apple-artiest, hoofdartiest als album-artiest, canonieke genre, albumhoes) en sorteert daarna in Artiest / Album (Jaar) / 'hoofdartiest - album - ## titel'. 'Alleen tonen' laat alles zien zonder iets te wijzigen." />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Map" />
                        <TextBox Grid.Column="1" Text="{Binding SourceFolder}" Watermark="Map om te organiseren (bijv. je downloadmap)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseOrganizeSource" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Bibliotheek" />
                        <TextBox Grid.Column="1" Text="{Binding DestFolder}" Watermark="Doelmap (leeg = in dezelfde map)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseOrganizeDest" />
                    </Grid>
                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <CheckBox Margin="0,0,16,0" Content="Alleen tonen (test)" IsChecked="{Binding TestMode}" />
                        <CheckBox Margin="0,0,16,0" Content="Album-match (MusicBrainz)" IsChecked="{Binding AlbumMatch}"
                                  ToolTip.Tip="Matcht elk album als geheel tegen een MusicBrainz-release voor consistente titels, tracknummers, jaar en album-artiest." />
                        <CheckBox Margin="0,0,16,0" Content="Albumhoes ophalen" IsChecked="{Binding FetchCover}"
                                  ToolTip.Tip="Haalt de albumhoes op (Cover Art Archive) en zet 'm in bestanden die er nog geen hebben." />
                        <CheckBox Margin="0,0,16,0" Content="Genre opschonen" IsChecked="{Binding CleanGenre}"
                                  ToolTip.Tip="Schrijft één canonieke genre terug." />
                        <CheckBox Margin="0,0,16,0" Content="ReplayGain" IsChecked="{Binding ReplayGain}"
                                  ToolTip.Tip="Analyseert het volume (EBU R128, via ffmpeg) en schrijft ReplayGain-tags zodat alles even hard speelt. Trager." />
                        <CheckBox Content="Songteksten (.lrc)" IsChecked="{Binding Lyrics}"
                                  ToolTip.Tip="Haalt songteksten op (lrclib) en schrijft een .lrc-bestand naast de track (gesynchroniseerd indien beschikbaar; gelezen door Rockbox)." />
                    </WrapPanel>
                    <Border Grid.Row="4" Classes="card" Margin="0,12,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,4" Margin="0,0,0,4" Command="{Binding ShowCommand}">
                                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding FileName}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Status}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Target}" Foreground="{DynamicResource TextMuted}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Row="5" Margin="0,10,0,0" Padding="10" CornerRadius="8" Background="#EEEEF0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <SelectableTextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                    <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Ongedaan maken" Command="{Binding UndoCommand}"
                                ToolTip.Tip="Zet de laatste sorteer-/organiseer-actie terug." />
                        <Button Grid.Column="2" Classes="ghost" Content="Stop" Width="90" Margin="8,0,0,0" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="3" Classes="primary" Content="Organiseer" Margin="8,0,0,0" Command="{Binding RunCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: ALAC-CONVERTER ============ -->
            <TabItem Header="ALAC-converter">
                <Grid x:CompileBindings="False" DataContext="{Binding Alac}" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="ALAC-converter" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Converteert een muziekmap (FLAC/WAV/AIFF) naar Apple Lossless (ALAC, .m4a) in een doelmap (bijv. je iPod-map). Bestanden die er al staan worden overgeslagen. Tags en albumhoes gaan mee." />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Bronmap" />
                        <TextBox Grid.Column="1" Text="{Binding SourceFolder}" Watermark="Muziekmap met FLAC/WAV" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseAlacSource" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Doelmap" />
                        <TextBox Grid.Column="1" Text="{Binding OutputFolder}" Watermark="iPod-map waar de ALAC komt" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseAlacOutput" />
                    </Grid>
                    <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                        <CheckBox Margin="0,0,16,0" Content="iPod-compatibel (16-bit / 44,1 kHz)" IsChecked="{Binding IpodCompatible}"
                                  ToolTip.Tip="Zet ALAC om naar 16-bit/44,1 kHz zodat het op een iPod 5.5G speelt. Hi-res (24-bit/96 kHz) wordt anders geweigerd door de iPod. Uit = bron-kwaliteit behouden." />
                        <CheckBox Margin="0,0,16,0" Content="Mappenstructuur behouden" IsChecked="{Binding MirrorStructure}"
                                  ToolTip.Tip="Behoudt de submappen van de bronmap in de doelmap." />
                        <CheckBox Margin="0,0,16,0" Content="Originelen verwijderen na conversie" IsChecked="{Binding DeleteOriginals}"
                                  ToolTip.Tip="Verwijdert het bronbestand nadat het succesvol is geconverteerd." />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Classes="label" Text="Gelijktijdig" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding Concurrency}" Minimum="1" Maximum="10" Increment="1" FormatString="0" Width="100"
                                           ToolTip.Tip="Aantal conversies tegelijk. Hoger = sneller (tot je aantal cores), maar meer CPU/schijf-belasting." />
                        </StackPanel>
                    </WrapPanel>
                    <Border Grid.Row="4" Classes="card" Margin="0,12,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,4" Margin="0,0,0,4" Command="{Binding ShowCommand}">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding StatusBrush}" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Row="5" Margin="0,10,0,0" Padding="10" CornerRadius="8" Background="#EEEEF0" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <SelectableTextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                    <Grid Grid.Row="6" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Stop" Width="90" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="2" Classes="primary" Content="Converteer naar ALAC" Margin="8,0,0,0" Command="{Binding ConvertCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: METADATA ============ -->
            <TabItem Header="Metadata">
                <Grid x:CompileBindings="False" DataContext="{Binding Meta}" RowDefinitions="Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                        <Button Grid.Column="0" Classes="ghost" Content="Open bestand…" Click="OnOpenMetaFile" />
                        <Button Grid.Column="1" Classes="ghost" Content="Open map…" Margin="8,0,0,0" Click="OnOpenMetaFolder" />
                        <Button Grid.Column="2" Classes="primary" Margin="8,0,0,0" Command="{Binding MatchAlbumCommand}"
                                ToolTip.Tip="Matcht het hele album tegen één release (Apple/Discogs/MusicBrainz) en past consistente tags + hoes toe op alle tracks.">
                            <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE019;" /><TextBlock Text="Album-match" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="ghost" Content="Auto-fill (per track)" Margin="8,0,0,0" Command="{Binding AutoFillCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="Apple-format" Margin="8,0,0,0" Command="{Binding ApplyAppleArtistCommand}" />
                        <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="12" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="{DynamicResource HeaderBlue}" FontSize="13" FontWeight="SemiBold" Text="{Binding Position}" />
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Classes="chipbtn" Content="Formulier" Command="{Binding ModeFormCommand}" Classes.active="{Binding IsFormMode}" />
                        <Button Classes="chipbtn" Content="Tabel" Margin="6,0,0,0" Command="{Binding ModeTableCommand}" Classes.active="{Binding IsTableMode}" />
                        <Button Classes="chipbtn" Content="Converters" Margin="6,0,0,0" Command="{Binding ModeConvCommand}" Classes.active="{Binding IsConvMode}" />
                        <TextBlock Classes="caption" Margin="14,0,0,0" VerticalAlignment="Center" Text="{Binding Grid.Status}" />
                    </StackPanel>
                    <Panel Grid.Row="2" Margin="0,14,0,0">
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsFormMode}">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Titel" /><TextBox Grid.Column="1" Text="{Binding Title}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Artiest" /><TextBox Grid.Column="1" Text="{Binding Artist}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album-artiest" /><TextBox Grid.Column="1" Text="{Binding AlbumArtist}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Album" /><TextBox Grid.Column="1" Text="{Binding Album}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Genre" /><TextBox Grid.Column="1" Text="{Binding Genre}" /></Grid>
                            <Grid ColumnDefinitions="110,*,90,*">
                                <TextBlock Grid.Column="0" Classes="label" Text="Track" /><TextBox Grid.Column="1" Text="{Binding Track}" />
                                <TextBlock Grid.Column="2" Classes="label" Text="Disc" Margin="12,0,10,0" /><TextBox Grid.Column="3" Text="{Binding Disc}" />
                            </Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="Jaar" /><TextBox Grid.Column="1" Text="{Binding Year}" /></Grid>
                            <Grid ColumnDefinitions="110,*"><TextBlock Classes="label" Text="AcoustID-key" /><TextBox Grid.Column="1" Text="{Binding AcoustIdKey}" Watermark="optioneel — voor ongetagde bestanden (gratis via acoustid.org)" /></Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Width="190" Margin="16,0,0,0">
                            <Border Width="190" Height="190" Background="{DynamicResource Recess}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="6">
                                <Image Source="{Binding AlbumArt}" Stretch="Uniform" />
                            </Border>
                            <Button Classes="ghost" Content="Afbeelding kiezen…" Margin="0,8,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnLoadMetaArt" />
                            <Button Classes="ghost" Content="Hoes verwijderen" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding RemoveArtCommand}" />
                        </StackPanel>

                    </Grid>

                    <!-- TABEL-modus (fase 2): Mp3tag-achtige grid-editor -->
                    <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsTableMode}">
                        <WrapPanel Grid.Row="0">
                            <TextBlock Classes="caption" Text="Acties (alle rijen, als wijziging):" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <Button Classes="ghost" Padding="10,5" Content="Apple-format" Command="{Binding Grid.ActionAppleCommand}" />
                            <Button Classes="ghost" Padding="10,5" Content="Genre normaliseren" Margin="6,0,0,0" Command="{Binding Grid.ActionGenreCommand}" />
                            <Button Classes="ghost" Padding="10,5" Content="Trim spaties" Margin="6,0,0,0" Command="{Binding Grid.ActionTrimCommand}" />
                        </WrapPanel>
                        <DataGrid Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Grid.Rows}" AutoGenerateColumns="False"
                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="" Binding="{Binding DirtyMark}" IsReadOnly="True" Width="28" />
                                <DataGridTextColumn Header="Bestand" Binding="{Binding FileName}" IsReadOnly="True" Width="210" />
                                <DataGridTextColumn Header="Titel" Binding="{Binding Title, Mode=TwoWay}" Width="*" />
                                <DataGridTextColumn Header="Artiest" Binding="{Binding Artist, Mode=TwoWay}" Width="150" />
                                <DataGridTextColumn Header="Album-artiest" Binding="{Binding AlbumArtist, Mode=TwoWay}" Width="150" />
                                <DataGridTextColumn Header="Album" Binding="{Binding Album, Mode=TwoWay}" Width="170" />
                                <DataGridTextColumn Header="Genre" Binding="{Binding Genre, Mode=TwoWay}" Width="110" />
                                <DataGridTextColumn Header="#" Binding="{Binding Track, Mode=TwoWay}" Width="46" />
                                <DataGridTextColumn Header="Jaar" Binding="{Binding Year, Mode=TwoWay}" Width="62" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                            <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Grid.DirtyText}" />
                            <Button Grid.Column="1" Classes="primary" Content="Bewaar wijzigingen" Command="{Binding Grid.SaveCommand}"
                                    ToolTip.Tip="Schrijft de gewijzigde rijen naar de bestanden (Cmd+Z = ongedaan maken)." />
                        </Grid>
                    </Grid>

                    <!-- CONVERTERS-modus (fase 2) -->
                    <ScrollViewer IsVisible="{Binding IsConvMode}" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <Border Classes="card">
                                <StackPanel>
                                    <TextBlock Classes="title" Text="Bestandsnaam → Tags" />
                                    <TextBlock Classes="caption" Margin="0,2,0,8" Text="Leest velden uit de bestandsnaam en vult de tabel als wijziging — controleer daar en klik Bewaar." />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Grid.PatternF2T}" Watermark="%artist% - %title%" />
                                        <Button Grid.Column="1" Classes="primary" Margin="8,0,0,0" Content="Vul tabel" Command="{Binding Grid.ApplyF2TCommand}" />
                                    </Grid>
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="{Binding Grid.PreviewF2T}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Classes="card">
                                <StackPanel>
                                    <TextBlock Classes="title" Text="Tags → Bestandsnaam" />
                                    <TextBlock Classes="caption" Margin="0,2,0,8" Text="Hernoemt de bestanden op basis van de (tabel)tags. Omkeerbaar met Cmd+Z." />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox Grid.Column="0" Text="{Binding Grid.PatternT2F}" Watermark="%track% %title%" />
                                        <Button Grid.Column="1" Classes="primary" Margin="8,0,0,0" Content="Hernoem bestanden" Command="{Binding Grid.ApplyT2FCommand}" />
                                    </Grid>
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="{Binding Grid.PreviewT2F}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <TextBlock Classes="caption" Text="Tokens: %artist%  %albumartist%  %album%  %title%  %track%  %disc%  %year%  %genre%" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Album-match candidate picker (overlay, alle modi) -->
                    <Border ZIndex="50" IsVisible="{Binding ShowCandidates}"
                                Background="{DynamicResource Surface}" CornerRadius="12">
                            <Border Classes="card">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Classes="h2" Text="Kies de juiste editie" />
                                        <TextBlock Classes="caption" Margin="0,2,0,0" Text="Wordt op álle tracks van het album toegepast: titels op trackpositie + consistente artiest/album/jaar/genre/hoes." />
                                    </StackPanel>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding AlbumCandidates}" SelectedItem="{Binding SelectedCandidate}"
                                             Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                                    <Border Grid.Column="0" CornerRadius="9999" Padding="9,3" VerticalAlignment="Center" Background="{DynamicResource PrimaryFixed}">
                                                        <TextBlock Text="{Binding Source}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Display}" Classes="title" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Sub}" Classes="caption" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                                        <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding Status}" />
                                        <Button Grid.Column="1" Classes="ghost" Content="Annuleren" Command="{Binding CancelCandidatesCommand}" />
                                        <Button Grid.Column="2" Classes="primary" Content="Pas toe op album" Margin="8,0,0,0" Command="{Binding ApplyAlbumMatchCommand}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Border>
                    </Panel>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="◀ Vorige  (←)" Command="{Binding BackCommand}" />
                        <Button Grid.Column="2" Classes="primary" Content="Goedkeuren ▶  (→)" Margin="8,0,0,0" Command="{Binding ApproveNextCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: BIBLIOTHEEK ============ -->
            <TabItem Header="Bibliotheek">
                <Grid x:CompileBindings="False" DataContext="{Binding Library}" RowDefinitions="Auto,*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Bibliotheek-gezondheid" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Scant je muziekbieb op ontbrekende tags/hoezen en lossy vs lossless. Klik een gemarkeerde kaart om die nummers meteen te herstellen." />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowDashboard}">
                      <StackPanel Spacing="14">
                        <!-- Health score hero -->
                        <Border Classes="card" Padding="20">
                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="caption" Text="GEZONDHEIDSSCORE" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding HealthScore}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                        <TextBlock Text="%" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Bottom" Margin="2,0,0,8" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding HealthScore}" Height="10" CornerRadius="5"
                                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" />
                                    <TextBlock Classes="caption" Margin="0,8,0,0" Text="Gewogen op volledige tags, albumhoezen en lossless-aandeel." />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <UniformGrid Columns="3" VerticalAlignment="Top">
                            <Button Classes="statbtn" Command="{Binding ShowFilesCommand}" ToolTip.Tip="Bekijk alle bestanden in je bibliotheek.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Text="{Binding FileCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource SurfaceVariant}">
                                            <TextBlock Classes="icon" Text="&#xE030;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Bestanden" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Bekijken" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowAlbumsCommand}" ToolTip.Tip="Bekijk alle albums; klap een album uit voor de nummers.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Text="{Binding AlbumCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource SurfaceVariant}">
                                            <TextBlock Classes="icon" Text="&#xE019;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Albums" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Bekijken" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowUpgradesCommand}" ToolTip.Tip="Bekijk welke albums naar FLAC te upgraden zijn en upgrade ze.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource Accent}" Text="{Binding UpgradeAlbumCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource PrimaryFixed}">
                                            <TextBlock Classes="icon" Text="&#xF0FB;" HorizontalAlignment="Center" Foreground="{DynamicResource Accent}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="FLAC-upgrades mogelijk" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Bekijken" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>

                            <!-- Clickable: jump to Metadata with the affected files -->
                            <Button Classes="statbtn" Command="{Binding EditNoTagsCommand}"
                                    ToolTip.Tip="Open deze nummers in Metadata om de tags aan te vullen.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding NoTagCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE892;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Zonder tags" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Herstellen" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding EditNoCoverCommand}"
                                    ToolTip.Tip="Open de nummers uit albums zonder hoes in Metadata om een hoes te zetten.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding NoCoverCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE3AD;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Albums zonder hoes" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Herstellen" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                            <Button Classes="statbtn" Command="{Binding ShowLossyCommand}"
                                    ToolTip.Tip="Bekijk de lossy bestanden en vervang ze door FLAC.">
                                <Grid RowDefinitions="Auto,Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="statNum" Foreground="{DynamicResource WarnFg}" Text="{Binding LossyFileCount, StringFormat=N0}" />
                                        <Border Grid.Column="1" Width="38" Height="38" CornerRadius="10" Background="{DynamicResource WarnBg}">
                                            <TextBlock Classes="icon" Text="&#xE1B8;" HorizontalAlignment="Center" Foreground="{DynamicResource WarnFg}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Classes="statLbl" Text="Lossy (MP3/AAC)" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="Bekijken" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                        <TextBlock Classes="icon" FontSize="16" Text="&#xE5C8;" Margin="2,0,0,0" Foreground="{DynamicResource Accent}" />
                                    </StackPanel>
                                </Grid>
                            </Button>
                        </UniformGrid>

                        <!-- Problematische albums -->
                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="title" Text="Problematische albums" />
                                <TextBlock Classes="caption" Margin="0,2,0,10" Text="Klik 'Herstel' om de nummers van dat album in Metadata te openen." />
                                <ItemsControl ItemsSource="{Binding ProblemAlbums}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ProblemAlbumViewModel">
                                            <Border Padding="12,9" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center">
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="body" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <Border Grid.Column="1" CornerRadius="9999" Padding="9,3" Margin="8,0,8,0" VerticalAlignment="Center" Background="{DynamicResource WarnBg}">
                                                        <TextBlock Text="{Binding Issue}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                                    </Border>
                                                    <Button Grid.Column="2" Classes="ghost" Padding="12,5" Command="{Binding FixCommand}" Content="Herstel" />
                                                    <Button Grid.Column="3" Classes="ghost" Padding="10,5" Margin="6,0,0,0" Command="{Binding DeleteCommand}"
                                                            ToolTip.Tip="Verplaatst dit album naar '_Verwijderd (Spindle)' náást je bibliotheek (buiten de bieb, omkeerbaar) — zodat sorteren/organiseren het niet terugzet.">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" />
                                                            <TextBlock Text="Verwijder" VerticalAlignment="Center" Foreground="{DynamicResource ErrorBrush}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                      </StackPanel>
                    </ScrollViewer>

                    <!-- Detail drill-down (clicking a stat box) -->
                    <Grid Grid.Row="1" Margin="0,16,0,0" RowDefinitions="Auto,*" IsVisible="{Binding ShowDetail}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                            <Button Grid.Column="0" Classes="ghost" Command="{Binding CloseDetailCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Classes="icon" FontSize="17" Text="&#xE5C4;" />
                                    <TextBlock Text="Overzicht" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="14,0,0,0" Classes="h2" Text="{Binding DetailTitle}" VerticalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" Classes="card" Padding="8">
                            <Grid>
                                <!-- Bestanden -->
                                <ListBox IsVisible="{Binding ShowFilesPanel}" ItemsSource="{Binding DetailFiles}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="13" Foreground="{DynamicResource TextPrimary}" Padding="6,3" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <!-- Albums (tree) -->
                                <TreeView IsVisible="{Binding ShowAlbumsPanel}" ItemsSource="{Binding AlbumTree}" Background="Transparent">
                                    <TreeView.DataTemplates>
                                        <TreeDataTemplate DataType="vm:HealthArtistNode" ItemsSource="{Binding Albums}">
                                            <TextBlock Text="{Binding Name}" Classes="title" FontSize="14" />
                                        </TreeDataTemplate>
                                        <TreeDataTemplate DataType="vm:HealthAlbumNode" ItemsSource="{Binding Tracks}">
                                            <TextBlock Text="{Binding Header}" FontSize="13" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" />
                                        </TreeDataTemplate>
                                    </TreeView.DataTemplates>
                                </TreeView>
                                <!-- Upgrades / Lossy list -->
                                <ScrollViewer IsVisible="{Binding ShowListPanel}" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DetailAlbums}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" Margin="2,2,2,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Classes="caption" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Hoezen repareren" Command="{Binding RepairCoversCommand}"
                                ToolTip.Tip="Haalt voor albums zonder hoes de albumhoes op (MusicBrainz/Cover Art Archive) en zet 'm in de bestanden + folder.jpg." />
                        <Button Grid.Column="2" Classes="ghost" Content="Stop" Width="80" Margin="8,0,0,0" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="3" Classes="primary" Content="Scan" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: DUBBELE ============ -->
            <TabItem Header="Dubbele">
                <Grid x:CompileBindings="False" DataContext="{Binding Duplicates}" RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="h2" Text="Dubbele opsporen" />
                        <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="Vindt tracks met dezelfde artiest + titel en toont de kopieën naast elkaar. Kies per set welke je houdt; de rest gaat naar de map '_Dubbele_verwijderd' (omkeerbaar)." />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Map" />
                        <TextBox Grid.Column="1" Text="{Binding Folder}" Watermark="Map om te doorzoeken (incl. submappen)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseDupFolder" />
                        <Button Grid.Column="3" Classes="primary" Content="Zoek dubbele" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                    <CheckBox Grid.Row="2" Margin="0,10,0,0" Content="Ook akoestische vingerafdruk over de rest (AcoustID)" IsChecked="{Binding UseFingerprint}"
                              ToolTip.Tip="Tweede pass over de bestanden die niet op tags matchten: herkent dezelfde opname ondanks afwijkende/missende tags. Vereist een AcoustID-key (Metadata-tab) en is traag (~3/sec)." />
                    <ScrollViewer Grid.Row="3" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Width="240" Margin="0,0,8,8" Padding="10" CornerRadius="8" Background="{DynamicResource Recess}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                                            <StackPanel Spacing="3">
                                                                <TextBlock Text="{Binding Quality}" Foreground="{DynamicResource HeaderBlue}" FontSize="13" FontWeight="Bold" />
                                                                <TextBlock Text="{Binding Album}" Foreground="{DynamicResource TextSecondary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                                                                <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource TextMuted}" FontSize="10" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Path}" />
                                                                <SelectableTextBlock Text="{Binding KeepLabel}" Foreground="{Binding KeepBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                                                <Button Classes="ghost" Content="Behoud deze" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding KeepCommand}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="ghost" Content="Stop" Width="90" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="2" Classes="primary" Content="Verwijder niet-gekozen" Margin="8,0,0,0" Command="{Binding RemoveCommand}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: OVERZETTEN ============ -->
            <TabItem Header="Overzetten">
                <Grid x:CompileBindings="False" DataContext="{Binding Sync}" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" Margin="0,12,0,0">
                    <Border Grid.Row="0" Classes="card" Padding="16,14">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12" Background="{DynamicResource SurfaceVariant}">
                                <TextBlock Classes="icon" FontSize="26" Text="&#xE32C;" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeviceText}" Classes="title" FontSize="15" />
                                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0" IsVisible="{Binding HasDevice}">
                                    <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding UsedPercent}" Height="8" CornerRadius="4"
                                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" Text="{Binding UsedPercent, StringFormat='{}{0}% vol'}" Classes="caption" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Bibliotheek" />
                        <TextBox Grid.Column="1" Text="{Binding LibraryFolder}" Watermark="Map met je muziek" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseSyncLibrary" />
                        <Button Grid.Column="3" Classes="primary" Content="Scan" Margin="8,0,0,0" Command="{Binding ScanCommand}" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,170,*,Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="Genre" />
                        <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" ItemsSource="{Binding Genres}" SelectedItem="{Binding SelectedGenre}" />
                        <TextBox Grid.Column="2" Margin="8,0,0,0" Text="{Binding SearchText}" Watermark="Zoek artiest/album…" />
                        <Button Grid.Column="3" Classes="ghost" Content="Alles" Margin="8,0,0,0" Command="{Binding SelectAllCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="Geen" Margin="6,0,0,0" Command="{Binding SelectNoneCommand}" />
                    </Grid>
                    <Border Grid.Row="3" Classes="card" Margin="0,12,0,0">
                        <TreeView ItemsSource="{Binding ArtistTree}">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="vm:ArtistNodeViewModel" ItemsSource="{Binding Albums}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsThreeState="True" IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="2,0,0,0" />
                                        <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </StackPanel>
                                </TreeDataTemplate>
                                <DataTemplate DataType="vm:AlbumEntryViewModel">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,1,0,1">
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" IsChecked="{Binding Selected}" />
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding Album}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Sub}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="11" FontWeight="SemiBold"
                                                   Text="{Binding IpodStatus}" Foreground="{Binding IpodBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </Border>
                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
                        <TextBlock Grid.Column="0" Classes="label" Text="iPod-map" />
                        <TextBox Grid.Column="1" Text="{Binding IpodFolder}" Watermark="De gekoppelde iPod (Rockbox)" />
                        <Button Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseSyncIpod" />
                    </Grid>
                    <StackPanel Grid.Row="5" Margin="0,12,0,0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8" IsVisible="{Binding IsTransferring}">
                        <ProgressBar Grid.Column="0" Minimum="0" Maximum="100" Value="{Binding TransferProgress}" Height="8" CornerRadius="4"
                                     Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Classes="caption" Text="{Binding TransferProgress, StringFormat='{}{0:0}%'}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Omzetten naar ALAC" IsChecked="{Binding ConvertToAlac}"
                                      ToolTip.Tip="Standaard uit = bestanden kopiëren zoals ze zijn (snelst; Rockbox speelt FLAC/MP3/AAC). Aan = alleen FLAC/WAV/AIFF worden omgezet naar ALAC 16-bit/44,1 kHz (bespaart accu op de iPod); MP3/AAC worden altijd gewoon gekopieerd." />
                            <TextBlock Text="✓ = op iPod · vink af om te verwijderen" Margin="16,0,0,0" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{DynamicResource TextMuted}" />
                        </StackPanel>
                        <SelectableTextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="2" Classes="ghost" Content=".m3u-playlists" Command="{Binding MakePlaylistsCommand}"
                                ToolTip.Tip="Maakt per albummap op de iPod een .m3u-playlist (gelezen door Rockbox)." />
                        <Button Grid.Column="3" Classes="ghost" Content="Stop" Width="90" Margin="8,0,0,0" Command="{Binding StopCommand}" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="4" Classes="primary" Content="Overzetten" Margin="8,0,0,0" Command="{Binding TransferCommand}" />
                    </Grid>
                    </StackPanel>
                    <Border Grid.Row="6" Margin="0,10,0,0" Padding="10" CornerRadius="8" Background="{DynamicResource ErrorBg}" BorderBrush="{DynamicResource ErrorBorder}" BorderThickness="1"
                            MaxHeight="150" IsVisible="{Binding HasFailures}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Mislukt" Foreground="#BA1A1A" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Failures}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <SelectableTextBlock Text="{Binding Line}" ToolTip.Tip="{Binding Path}" Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,3" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ TAB: INSTELLINGEN ============ -->
            <TabItem Header="Instellingen">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel Spacing="12" Margin="0,0,6,0">

                        <StackPanel Margin="0,0,0,2">
                            <TextBlock Classes="h2" Text="Instellingen" />
                            <TextBlock Classes="body" Margin="0,4,0,0" Text="Mappen en metadata-bronnen voor het beheren en opschonen van je collectie." />
                        </StackPanel>

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="section" Text="METADATA-BRONNEN" />
                                <Grid ColumnDefinitions="105,*">
                                    <TextBlock Grid.Column="0" Classes="label" Text="Discogs-token" />
                                    <TextBox Grid.Column="1" Text="{Binding DiscogsToken}" Watermark="optioneel — gratis token via discogs.com/settings/developers" />
                                </Grid>
                                <TextBlock Classes="caption" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Album-match gebruikt Apple/iTunes (geen sleutel nodig) + MusicBrainz. Een Discogs-token voegt vinyl/electronic-edities toe." />
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="GALAXY" />
                                <CheckBox Content="Album-niveau (sneller bij grote collecties)" IsChecked="{Binding GalaxyAlbumLevel}"
                                          ToolTip.Tip="Eén punt per album in plaats van per nummer. Aangeraden boven ±20.000 nummers (≈ 1 TB)." />
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel>
                                <TextBlock Classes="section" Text="MAPPEN" />
                                <Grid ColumnDefinitions="110,*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Nieuwe muziek" />
                                    <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding DownloadFilePath}" Watermark="Map waar Nicotine+ in downloadt (de bron om te organiseren)" />
                                    <Button   Grid.Row="0" Grid.Column="2" Classes="ghost" Content="Bladeren…" Margin="8,0,0,0" Click="OnBrowseDownloadFolder" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Muziekbieb" Margin="0,8,10,0" />
                                    <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding MusicLibrary}" Watermark="~/Music — je geordende collectie" />
                                    <Button   Grid.Row="1" Grid.Column="2" Classes="ghost" Margin="8,8,0,0" Content="Bladeren…" Click="OnBrowseMusicLibrary" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="BESTANDSNAMEN" />
                                <TextBlock Classes="label" Text="Sjabloon (Sorteren &amp; Organiseren)" />
                                <TextBox Text="{Binding FilenameTemplate}" Watermark="{}{artist} - {album} - {track} {title}"
                                         ToolTip.Tip="Tokens: {artist} {album} {title} {track} {year}. Lege tokens vallen netjes weg. De mapstructuur blijft Artiest / Album (Jaar)." />
                                <TextBlock Text="Tokens: {artist} {album} {title} {track} {year}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ TAB: NIEUW (review-gate) ============ -->
            <TabItem Header="Nieuw">
                <Grid x:CompileBindings="False" DataContext="{Binding Staging}" RowDefinitions="Auto,Auto,*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="h2" Text="Nieuw — controleren &amp; goedkeuren" />
                            <TextBlock Classes="body" Margin="0,4,0,0" TextWrapping="Wrap"
                                       Text="Wat Nicotine+ binnenhaalde, per album met aandachtsvlaggen. Fix inline, vink aan en keur goed — met diff-preview netjes als Artiest/Album (Jaar) in de bieb geplaatst." />
                            <TextBlock Classes="body" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="0,8,0,0"
                                       Text="{Binding PipelineText}" IsVisible="{Binding PipelineText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="primary" VerticalAlignment="Top" Command="{Binding ScanCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE8B6;" /><TextBlock Text="Scan Nieuw" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowAlbumList}">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Classes="caption" Text="{Binding Summary}" />
                        <CheckBox Grid.Column="1" Margin="0,0,12,0" Content="Alleen aandachtspunten" IsChecked="{Binding ShowOnlyIssues}" />
                        <Button Grid.Column="2" Classes="ghost" Content="Schoon" Command="{Binding SelectCleanCommand}" ToolTip.Tip="Selecteer alle schone albums die nog niet in de bieb staan." />
                        <Button Grid.Column="3" Classes="ghost" Content="Alles" Margin="6,0,0,0" Command="{Binding SelectAllCommand}" />
                        <Button Grid.Column="4" Classes="ghost" Content="Geen" Margin="6,0,0,0" Command="{Binding SelectNoneCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto" IsVisible="{Binding ShowAlbumList}">
                        <ItemsControl ItemsSource="{Binding Albums}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Margin="0,0,0,8" Padding="12">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                                            <CheckBox Grid.Column="0" VerticalAlignment="Center" IsChecked="{Binding IsSelected}" />
                                            <Border Grid.Column="1" Width="56" Height="56" CornerRadius="8" Margin="4,0,0,0" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                                <Panel>
                                                    <TextBlock Classes="icon" FontSize="24" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}"
                                                               IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                                    <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Classes="title" FontSize="14" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Sub}" Classes="caption" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Border CornerRadius="9999" Padding="9,3" Background="{DynamicResource SuccessBg}" IsVisible="{Binding IsClean}">
                                                        <TextBlock Text="✓ schoon" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Success}" />
                                                    </Border>
                                                    <ItemsControl ItemsSource="{Binding Flags}">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="9999" Padding="9,3" Margin="0,0,6,0" Background="{DynamicResource WarnBg}">
                                                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="3" Classes="ghost" VerticalAlignment="Center" Command="{Binding FixCommand}" IsVisible="{Binding HasFlags}">
                                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Fix" VerticalAlignment="Center" /></StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Map-inspecteur (Fix) -->
                    <Grid Grid.Row="2" Margin="0,12,0,0" RowDefinitions="Auto,*" IsVisible="{Binding ShowDetail}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                            <Button Grid.Column="0" Classes="ghost" Command="{Binding BackCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="17" Text="&#xE5C4;" /><TextBlock Text="Terug" VerticalAlignment="Center" /></StackPanel>
                            </Button>
                            <TextBlock Grid.Column="1" Margin="14,0,0,0" Classes="h2" Text="{Binding DetailTitle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="2" Classes="ghost" Command="{Binding EditInMetadataCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Bewerk in Metadata" VerticalAlignment="Center" /></StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <Border Classes="card" IsVisible="{Binding HasDuplicates}">
                                    <StackPanel>
                                        <TextBlock Classes="title" Text="Dubbele in deze map" />
                                        <ItemsControl ItemsSource="{Binding DetailDuplicates}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" />
                                                            <ItemsControl ItemsSource="{Binding Files}" Margin="0,4,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding Meta}" Classes="caption" FontSize="10" TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                            <Button Grid.Column="1" Classes="ghost" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center" Command="{Binding PlayCommand}" ToolTip.Tip="10 sec. preview"><TextBlock Classes="icon" FontSize="15" Text="&#xE037;" Foreground="{DynamicResource Accent}" /></Button>
                                                                            <Border Grid.Column="2" Classes="badge" Margin="8,0,8,0" VerticalAlignment="Center"><TextBlock Text="{Binding Format}" /></Border>
                                                                            <Button Grid.Column="3" Classes="ghost" Padding="8,3" VerticalAlignment="Center" Command="{Binding DeleteCommand}" ToolTip.Tip="Verwijder dit bestand (naar _Verwijderd, omkeerbaar)."><TextBlock Classes="icon" FontSize="15" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" /></Button>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Classes="card">
                                    <StackPanel>
                                        <TextBlock Classes="title" Text="Bestanden" />
                                        <ItemsControl ItemsSource="{Binding DetailFiles}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="8" Background="{DynamicResource Recess}">
                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center">
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding FileName}" Classes="title" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Meta}" Classes="caption" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                                <ItemsControl ItemsSource="{Binding Issues}" IsVisible="{Binding HasIssues}" Margin="0,4,0,0">
                                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border CornerRadius="9999" Padding="8,2" Margin="0,0,6,0" Background="{DynamicResource WarnBg}"><TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource WarnFg}" /></Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Classes="ghost" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center" Command="{Binding PlayCommand}" ToolTip.Tip="10 sec. preview"><TextBlock Classes="icon" FontSize="16" Text="&#xE037;" Foreground="{DynamicResource Accent}" /></Button>
                                                            <Border Grid.Column="2" Classes="badge" Margin="8,0,8,0" VerticalAlignment="Center"><TextBlock Text="{Binding Format}" /></Border>
                                                            <Button Grid.Column="3" Classes="ghost" Padding="8,4" VerticalAlignment="Center" Command="{Binding DeleteCommand}" ToolTip.Tip="Verwijder dit bestand (naar _Verwijderd, omkeerbaar)."><TextBlock Classes="icon" FontSize="16" Text="&#xE872;" Foreground="{DynamicResource ErrorBrush}" /></Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Inline taggen (fase 3): tabel in de inspecteur zelf -->
                                <Border Classes="card" Margin="0,12,0,0">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Grid.Row="0" Classes="title" Text="Tags bewerken (tabel)" />
                                        <DataGrid Grid.Row="1" Margin="0,8,0,0" MaxHeight="320" ItemsSource="{Binding FixGrid.Rows}" AutoGenerateColumns="False"
                                                  CanUserResizeColumns="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                                  Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="" Binding="{Binding DirtyMark}" IsReadOnly="True" Width="24" />
                                                <DataGridTextColumn Header="Titel" Binding="{Binding Title, Mode=TwoWay}" Width="*" />
                                                <DataGridTextColumn Header="Artiest" Binding="{Binding Artist, Mode=TwoWay}" Width="140" />
                                                <DataGridTextColumn Header="Album" Binding="{Binding Album, Mode=TwoWay}" Width="150" />
                                                <DataGridTextColumn Header="Genre" Binding="{Binding Genre, Mode=TwoWay}" Width="100" />
                                                <DataGridTextColumn Header="#" Binding="{Binding Track, Mode=TwoWay}" Width="42" />
                                                <DataGridTextColumn Header="Jaar" Binding="{Binding Year, Mode=TwoWay}" Width="56" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                            <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding FixGrid.DirtyText}" />
                                            <Button Grid.Column="1" Classes="primary" Padding="14,6" Content="Bewaar" Command="{Binding FixGrid.SaveCommand}"
                                                    ToolTip.Tip="Schrijft de gewijzigde rijen (Cmd+Z = ongedaan maken)." />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,12,0,0" IsVisible="{Binding ShowAlbumList}">
                        <SelectableTextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding Status}" />
                        <Button Grid.Column="1" Classes="primary" Command="{Binding ApproveCommand}"
                                ToolTip.Tip="Verplaats de aangevinkte albums naar je muziekbieb en sorteer de hele collectie opnieuw.">
                            <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Classes="icon" FontSize="18" Text="&#xE161;" /><TextBlock Text="Goedkeuren → bieb" VerticalAlignment="Center" /></StackPanel>
                        </Button>
                    </Grid>

                    <!-- Diff-preview van Goedkeuren (fase 3) -->
                    <Grid Grid.Row="0" Grid.RowSpan="4" ZIndex="60" IsVisible="{Binding ShowPlan}">
                        <Border Background="#33000000" />
                        <Border MaxWidth="760" Margin="40,16" Classes="card" VerticalAlignment="Center">
                            <Grid RowDefinitions="Auto,*,Auto" MaxHeight="560">
                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Classes="h2" Text="Controleer de verplaatsing" />
                                    <TextBlock Classes="caption" Margin="0,4,0,0" Text="{Binding PlanSummary}" />
                                </StackPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding PlanItems}" Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,2">
                                                <TextBlock Text="{Binding FromText}" FontSize="12" Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Classes="icon" FontSize="14" Text="&#xE5C8;" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding ToText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                                    <Button Grid.Column="1" Classes="ghost" Content="Annuleren" Command="{Binding CancelPlanCommand}" />
                                    <Button Grid.Column="2" Classes="primary" Margin="8,0,0,0" Command="{Binding ConfirmPlanCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Classes="icon" FontSize="18" Text="&#xE161;" /><TextBlock Text="Verplaats naar bieb" VerticalAlignment="Center" /></StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ TAB: BIBLIOTHEEK-BROWSER (fase 1) ============ -->
            <TabItem Header="Bibliotheek">
                <Grid x:CompileBindings="False" DataContext="{Binding Browser}" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="h2" Text="Bibliotheek" />
                                <TextBlock Classes="caption" Margin="0,2,0,0" Text="{Binding Status}" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="ghost" VerticalAlignment="Top" Command="{Binding RefreshCommand}" ToolTip.Tip="Opnieuw uit de index lezen.">
                                <TextBlock Classes="icon" FontSize="17" Text="&#xE5D5;" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,12,0,0">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="Zoek artiest of album…" Margin="0,0,10,0" />
                            <Button Grid.Column="1" Classes="chipbtn" Content="Alles" Command="{Binding FilterAllCommand}" Classes.active="{Binding IsFilterAll}" />
                            <Button Grid.Column="2" Classes="chipbtn" Content="Lossy" Margin="6,0,0,0" Command="{Binding FilterLossyCommand}" Classes.active="{Binding IsFilterLossy}" />
                            <Button Grid.Column="3" Classes="chipbtn" Content="Zonder hoes" Margin="6,0,0,0" Command="{Binding FilterNoCoverCommand}" Classes.active="{Binding IsFilterNoCover}" />
                            <Button Grid.Column="4" Classes="chipbtn" Content="Zonder tags" Margin="6,0,0,0" Command="{Binding FilterNoTagsCommand}" Classes.active="{Binding IsFilterNoTags}" />
                        </Grid>

                        <ListBox Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Albums}" SelectedItem="{Binding SelectedAlbum}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="150" Margin="2">
                                        <Border Width="150" Height="150" CornerRadius="10" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                            <Panel>
                                                <TextBlock Classes="icon" FontSize="44" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                                            </Panel>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" Classes="title" FontSize="13" Margin="2,8,2,0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ArtistText}" Classes="caption" Margin="2,1,2,0" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="2,4,2,0" IsVisible="{Binding HasIssues}">
                                            <Ellipse Width="7" Height="7" Fill="{DynamicResource WarnFg}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding FlagText}" FontSize="10" Foreground="{DynamicResource WarnFg}" Margin="4,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Inspector -->
                    <Border Grid.Column="1" Width="300" Margin="16,0,0,0" Classes="card" Padding="16"
                            IsVisible="{Binding SelectedAlbum, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Width="260" Height="260" CornerRadius="12" ClipToBounds="True" Background="{DynamicResource SurfaceVariant}">
                                    <Panel>
                                        <TextBlock Classes="icon" FontSize="64" Text="&#xE019;" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   IsVisible="{Binding SelectedAlbum.Cover, Converter={x:Static ObjectConverters.IsNull}}" />
                                        <Image Source="{Binding SelectedAlbum.Cover}" Stretch="UniformToFill" />
                                    </Panel>
                                </Border>
                                <TextBlock Text="{Binding SelectedAlbum.Title}" Classes="title" FontSize="16" Margin="0,12,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedAlbum.ArtistText}" Classes="body" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding SelectedAlbum.Sub}" Classes="caption" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding SelectedAlbum.FlagText}" FontSize="11" Foreground="{DynamicResource WarnFg}" Margin="0,4,0,0"
                                           IsVisible="{Binding SelectedAlbum.HasIssues}" />

                                <TextBlock Classes="section" Text="ALBUM-VELDEN (HEEL ALBUM)" Margin="0,16,0,8" />
                                <TextBox Text="{Binding EditArtist}" Watermark="Album-artiest" />
                                <TextBox Text="{Binding EditAlbum}" Watermark="Album" Margin="0,6,0,0" />
                                <Grid ColumnDefinitions="*,90" Margin="0,6,0,0">
                                    <TextBox Grid.Column="0" Text="{Binding EditGenre}" Watermark="Genre" />
                                    <TextBox Grid.Column="1" Text="{Binding EditYear}" Watermark="Jaar" Margin="6,0,0,0" />
                                </Grid>
                                <Button Classes="primary" Content="Bewaar voor heel album" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                        Command="{Binding SaveAlbumEditCommand}" />

                                <TextBlock Classes="section" Text="NUMMERS" Margin="0,16,0,8" />
                                <ListBox MaxHeight="240" ItemsSource="{Binding SelectedTracks}" SelectedItem="{Binding SelectedTrack}"
                                         Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Display}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Right}" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Classes="caption" Margin="0,4,0,0" Text="Spatie = 10 sec. preview" />

                                <Button Classes="ghost" Margin="0,14,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding EditInMetadataCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE892;" /><TextBlock Text="Bewerk in Metadata" VerticalAlignment="Center" /></StackPanel>
                                </Button>
                                <Button Classes="ghost" Margin="0,6,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding ShowInFinderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Classes="icon" FontSize="16" Text="&#xE2C8;" /><TextBlock Text="Toon in Finder" VerticalAlignment="Center" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============ TAB: GALAXY (fase 4) ============ -->
            <TabItem Header="Galaxy">
                <Grid x:CompileBindings="False" DataContext="{Binding Galaxy}" RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="h2" Text="Galaxy" />
                            <TextBlock Classes="caption" Margin="0,2,0,0" Text="{Binding Status}" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="chipbtn" Content="Alles" VerticalAlignment="Top" Command="{Binding FilterAllCommand}" Classes.active="{Binding IsFilterAll}" />
                        <Button Grid.Column="2" Classes="chipbtn" Content="Lossy" Margin="6,0,0,0" VerticalAlignment="Top" Command="{Binding FilterLossyCommand}" Classes.active="{Binding IsFilterLossy}" />
                        <Button Grid.Column="3" Classes="chipbtn" Content="Zonder hoes" Margin="6,0,0,0" VerticalAlignment="Top" Command="{Binding FilterNoCoverCommand}" Classes.active="{Binding IsFilterNoCover}" />
                        <Button Grid.Column="4" Classes="ghost" Margin="10,0,0,0" VerticalAlignment="Top" Command="{Binding RefreshCommand}" ToolTip.Tip="Opnieuw opbouwen uit de index.">
                            <TextBlock Classes="icon" FontSize="17" Text="&#xE5D5;" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,10,0,0" CornerRadius="10" Padding="12,8" Background="{DynamicResource WarnBg}" IsVisible="{Binding WarningVisible}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WarnFg}" VerticalAlignment="Center" Text="{Binding WarningText}" />
                            <Button Grid.Column="1" Classes="ghost" Margin="10,0,0,0" Content="Schakel naar album-niveau" Command="{Binding SwitchToAlbumsCommand}" />
                        </Grid>
                    </Border>

                    <views:GalaxyControl Grid.Row="2" Margin="0,12,0,0" />
                </Grid>
            </TabItem>
        </TabControl>

            <!-- Globale statusbalk (fase 0): indexvoortgang + laatste actie -->
            <Border Grid.Row="2" Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="0,1,0,0" Padding="24,5">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="caption" VerticalAlignment="Center" Text="{Binding GlobalStatus}" />
                    <ProgressBar Grid.Column="1" Width="160" Height="6" CornerRadius="3" Minimum="0" Maximum="100"
                                 Value="{Binding IndexPercent}" IsVisible="{Binding IndexBusy}"
                                 Background="{DynamicResource SurfaceVariant}" Foreground="{DynamicResource Accent}"
                                 VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Cmd+F command palette ===== -->
        <Grid Grid.Column="0" Grid.ColumnSpan="2" ZIndex="100" IsVisible="{Binding IsPaletteOpen}">
            <Border Background="#33000000" PointerPressed="OnPaletteBackdrop" />
            <Border VerticalAlignment="Top" HorizontalAlignment="Center" Width="560" Margin="0,90,0,0"
                    Background="{DynamicResource Card}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="14" Padding="8" BoxShadow="0 20 50 0 #44000000">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,*" Margin="8,4">
                        <TextBlock Classes="icon" FontSize="20" Text="&#xE8B6;" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" />
                        <TextBox x:Name="PaletteBox" Grid.Column="1" Margin="8,0,0,0" Text="{Binding PaletteQuery}"
                                 Background="Transparent" BorderThickness="0" FontSize="16"
                                 Watermark="Spring naar een scherm…" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardBorder}" Margin="0,6" />
                    <ListBox MaxHeight="360" ItemsSource="{Binding PaletteResults}" SelectedItem="{Binding SelectedPaletteItem}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PaletteItem">
                                <Button Command="{Binding RunCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="Transparent" BorderThickness="0" Padding="8,6">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8" Background="{DynamicResource Recess}">
                                            <TextBlock Classes="icon" FontSize="18" Text="{Binding Glyph}" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Classes="title" FontSize="14" />
                                            <TextBlock Text="{Binding Subtitle}" Classes="caption" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
